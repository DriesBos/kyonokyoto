---
import "../styles/reset.css";
import "../styles/app.sass";
import type { AppLocale } from "../lib/i18n";
import { uiText } from "../lib/i18n";

type Props = {
  title?: string;
  description?: string;
  locale?: AppLocale;
  landingActive?: boolean;
};

const {
  locale = "en",
  title = uiText.en.title,
  description = uiText.en.description,
  landingActive = false,
} = Astro.props;

const appName = "KyōNoKyōto";
const ogImage = new URL("/og.png", Astro.url).href;
const shouldRegisterServiceWorker = import.meta.env.PROD;

Astro.response.headers.set("X-Robots-Tag", "noindex, nofollow, noarchive");
---

<html lang={uiText[locale].lang} data-landing-active={landingActive ? "" : undefined}>
  <head>
    <meta charset="utf-8" />
    <link
      rel="preload"
      href="/fonts/GT-Walsheim-Regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="512x512" href="/apple-touch-icon-512.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no, viewport-fit=cover"
    />
    <meta name="theme-color" content={landingActive ? "#138e00" : "#EFEFEF"} />
    <meta name="application-name" content={appName} />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content={appName} />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content="noindex, nofollow, noarchive" />
    <script is:inline>
      history.scrollRestoration = "manual";
    </script>
    {
      shouldRegisterServiceWorker ? (
        <script is:inline>
          if ("serviceWorker" in navigator) {
            window.addEventListener("load", () => {
              navigator.serviceWorker.register("/sw.js").catch(() => {
                // Ignore registration failures so the app still loads normally.
              });
            });
          }
        </script>
      ) : (
        <script is:inline>
          if ("serviceWorker" in navigator) {
            navigator.serviceWorker.getRegistrations().then((registrations) => {
              registrations.forEach((registration) => registration.unregister());
            });
          }

          if ("caches" in window) {
            caches.keys().then((keys) => {
              keys.filter((key) => key.startsWith("kyo-no-kyoto")).forEach((key) => caches.delete(key));
            });
          }
        </script>
      )
    }
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />
    <script is:inline type="text/partytown" src="https://www.googletagmanager.com/gtag/js?id=G-4EYJPD08Y4" async></script>
    <script is:inline type="text/partytown">
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }
      gtag('js', new Date());
      gtag('config', 'G-4EYJPD08Y4');
    </script>
  </head>
  <body>
    <slot />
    <script>
      if (!window.__siteCursorBound) {
        const supportsSiteCursor = window.matchMedia("(hover: hover) and (pointer: fine)");
        const activeCursorSelector = [
          ".general-button:not(.general-button--disabled):not([aria-disabled='true']):not([disabled])",
          ".page-edge-strokes__scroll-top:not([disabled])",
          "a[href]",
          "button:not([disabled])",
        ].join(",");
        const nativeCursorSelector = [
          "[data-map-resizer]",
          "[data-content-container][data-map-resizing]",
        ].join(",");
        let cursorDot = null;
        let cursorEnabled = false;

        const ensureCursorDot = () => {
          if (cursorDot) return cursorDot;

          cursorDot = document.createElement("div");
          cursorDot.className = "site-cursor-dot";
          cursorDot.setAttribute("aria-hidden", "true");
          document.body.append(cursorDot);
          return cursorDot;
        };

        const shouldUseNativeCursor = (target) => {
          return target instanceof Element && Boolean(target.closest(nativeCursorSelector));
        };

        const setCursorScale = (target) => {
          const dot = ensureCursorDot();
          let scale = 1;

          if (target instanceof Element) {
            scale = target.closest(activeCursorSelector) ? 0.5 : 1;
          }

          dot.style.setProperty("--cursor-dot-scale", String(scale));
        };

        const syncNativeCursor = (target) => {
          const useNativeCursor = shouldUseNativeCursor(target);
          document.body.toggleAttribute("data-site-native-cursor", useNativeCursor);
          return useNativeCursor;
        };

        const handlePointerMove = (event) => {
          const dot = ensureCursorDot();
          const useNativeCursor = syncNativeCursor(event.target);
          dot.style.setProperty("--cursor-dot-x", `${event.clientX}px`);
          dot.style.setProperty("--cursor-dot-y", `${event.clientY}px`);
          dot.style.opacity = useNativeCursor ? "0" : "1";
          setCursorScale(event.target);
        };

        const handlePointerLeave = () => {
          if (cursorDot) cursorDot.style.opacity = "0";
          document.body.removeAttribute("data-site-native-cursor");
        };

        const handlePointerOver = (event) => {
          const useNativeCursor = syncNativeCursor(event.target);
          if (cursorDot) cursorDot.style.opacity = useNativeCursor ? "0" : "1";
          setCursorScale(event.target);
        };

        const syncSiteCursor = () => {
          if (supportsSiteCursor.matches) {
            ensureCursorDot();
            if (cursorEnabled) return;

            document.addEventListener("pointermove", handlePointerMove, { passive: true });
            document.addEventListener("pointerover", handlePointerOver, { passive: true });
            document.addEventListener("pointerleave", handlePointerLeave, { passive: true });
            cursorEnabled = true;
            return;
          }

          cursorDot?.remove();
          cursorDot = null;
          document.body.removeAttribute("data-site-native-cursor");
          document.removeEventListener("pointermove", handlePointerMove);
          document.removeEventListener("pointerover", handlePointerOver);
          document.removeEventListener("pointerleave", handlePointerLeave);
          cursorEnabled = false;
        };

        syncSiteCursor();
        supportsSiteCursor.addEventListener("change", syncSiteCursor);
        window.__siteCursorBound = true;
      }
    </script>
  </body>
</html>
