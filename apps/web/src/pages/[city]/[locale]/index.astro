---
import EventCard from '../../../components/EventCard.astro';
import Footer from '../../../components/Footer.astro';
import GoogleMapCanvas from '../../../components/GoogleMapCanvas.astro';
import Header from '../../../components/Header.astro';
import Landing from '../../../components/Landing.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TimeDivider from '../../../components/TimeDivider.astro';
import kyotoPermanentPayload from '../../../../../../data/permanent/kyoto-permanent.json';
import osakaPermanentPayload from '../../../../../../data/permanent/osaka-permanent.json';
import tokyoPermanentPayload from '../../../../../../data/permanent/tokyo-permanent.json';
import kyotoSourcesPayload from '../../../../../../data/sources/kyoto-sources.json';
import osakaSourcesPayload from '../../../../../../data/sources/osaka-sources.json';
import tokyoSourcesPayload from '../../../../../../data/sources/tokyo-sources.json';
import { CITY_COOKIE, cityConfigFor, normalizeCity, type AppCity } from '../../../lib/cities';
import {
  LOCALE_COOKIE,
  normalizeLocale,
  resolveLocale,
  supportedLocales,
  uiText,
} from '../../../lib/i18n';
import { routePathFor } from '../../../lib/routeState';
import {
  calendarDetailsFor,
  calendarLocationFor,
  cleanDisplayText,
  googleCalendarUrl,
  mapsUrl,
} from '../../../lib/calendar';
import {
  displayEventsByLocale as buildDisplayEventsByLocale,
  fetchPublishedEvents,
} from '../../../lib/events';
import {
  permanentEventsByLocale as buildPermanentEventsByLocale,
  type PermanentExhibitionHighlight,
} from '../../../lib/permanentExhibitions';
import {
  allActiveSourcesFrom,
  categoriesForEvents,
  configuredSourcesFrom,
  mapCoordinatesForEvent,
  mapLocationIdForEvent,
  mapSourcesForEvents,
  sourceSlugForEvent,
  type SourceConfig,
} from '../../../lib/sources';
import { landingSlidesForEvents } from '../../../lib/landingSlides';

export const prerender = false;

Astro.response.headers.set(
  'Cache-Control',
  'public, max-age=60, s-maxage=300, stale-while-revalidate=86400',
);
Astro.response.headers.set(
  'Netlify-CDN-Cache-Control',
  'public, s-maxage=300, stale-while-revalidate=86400',
);

const routeCity = cityConfigFor(Astro.params.city);
const routeLocale = normalizeLocale(Astro.params.locale);
const fallbackCity = normalizeCity(Astro.cookies.get(CITY_COOKIE)?.value) ?? 'kyoto';
const fallbackLocale = resolveLocale({
  cookieLocale: Astro.cookies.get(LOCALE_COOKIE)?.value,
  acceptLanguage: Astro.request.headers.get('accept-language'),
});
const city = routeCity?.slug ?? fallbackCity;
const locale = routeLocale ?? fallbackLocale;
if (!routeCity || !routeLocale) return Astro.redirect(routePathFor({ city, locale }), 302);
if (Astro.params.city !== city || Astro.params.locale !== routeLocale) {
  return Astro.redirect(routePathFor({ city, locale }), 302);
}

const copy = uiText.en;
const metaCopy = uiText[locale];
const cityConfig = routeCity ?? cityConfigFor('kyoto')!;
const cityMetaTitle =
  city === 'kyoto' ? metaCopy.title : `${cityConfig.label} | ${uiText.en.title}`;
const cityMetaDescription =
  city === 'kyoto'
    ? metaCopy.description
    : metaCopy.description
        .replaceAll('Kyōto', cityConfig.label)
        .replaceAll('Kyoto', cityConfig.label)
        .replaceAll('京都', cityConfig.label);
const sourcesPayloadByCity = {
  kyoto: kyotoSourcesPayload,
  osaka: osakaSourcesPayload,
  tokyo: tokyoSourcesPayload,
} satisfies Record<AppCity, { sources: SourceConfig[] }>;
const permanentPayloadByCity = {
  kyoto: kyotoPermanentPayload,
  osaka: osakaPermanentPayload,
  tokyo: tokyoPermanentPayload,
} satisfies Record<AppCity, { items: PermanentExhibitionHighlight[] }>;
const sourcesPayload = sourcesPayloadByCity[city];
const permanentHighlightsPayload = permanentPayloadByCity[city];

const configuredSources = configuredSourcesFrom(sourcesPayload.sources as SourceConfig[]);
const allActiveSources = allActiveSourcesFrom(sourcesPayload.sources as SourceConfig[]);
const betaSourceSlugsAll = new Set(allActiveSources.filter((s) => s.beta).map((s) => s.slug));
const rawEvents = await fetchPublishedEvents();
const cityEvents = rawEvents.filter((event) => sourceSlugForEvent(event, allActiveSources));
const events = import.meta.env.DEV
  ? cityEvents
  : cityEvents.filter((event) => {
      const slug = sourceSlugForEvent(event, allActiveSources);
      return !slug || !betaSourceSlugsAll.has(slug);
    });
const displayEventsByLocale = buildDisplayEventsByLocale({
  events,
  configuredSources,
  supportedLocales,
});
const permanentEventsByLocale = buildPermanentEventsByLocale({
  highlights: permanentHighlightsPayload.items as PermanentExhibitionHighlight[],
  configuredSources,
  supportedLocales,
});
const displayEvents = displayEventsByLocale[locale];
const permanentEvents = permanentEventsByLocale[locale];
const visibleCards = [...displayEvents, ...permanentEvents];
const categories = categoriesForEvents(visibleCards);
const ongoingEvents = displayEvents.filter((event) => event.timing === 'ongoing');
const upcomingEvents = displayEvents.filter((event) => event.timing === 'upcoming');
const sourceSlugForDisplayEvent = (event: (typeof visibleCards)[number]) =>
  event.timing === 'permanent' ? event.source_id : sourceSlugForEvent(event, configuredSources);
const sourceSlugByEventId = new Map(
  visibleCards.map((event) => [event.id, sourceSlugForDisplayEvent(event)]),
);
const betaSourceSlugs = betaSourceSlugsAll;
const betaPermanentSlugs = new Set(
  (permanentHighlightsPayload.items as PermanentExhibitionHighlight[])
    .filter((h) => h.beta)
    .map((h) => h.slug),
);
const isEventBeta = (event: (typeof visibleCards)[number]) =>
  betaSourceSlugs.has(sourceSlugByEventId.get(event.id) ?? '') ||
  (event.timing === 'permanent' && betaPermanentSlugs.has(event.source_id));
const mapLocationIdByEventId = new Map(
  visibleCards.map((event) => [
    event.id,
    mapLocationIdForEvent(event, sourceSlugByEventId.get(event.id) ?? null, configuredSources),
  ]),
);
const mapSources = mapSourcesForEvents(visibleCards, sourceSlugByEventId, configuredSources);
const landingSlides = landingSlidesForEvents({
  city,
  events: displayEvents,
  sourceSlugByEventId,
});

const mapsUrlForEvent = (event: (typeof displayEvents)[number]) => {
  const sourceSlug =
    sourceSlugByEventId.get(event.id) ?? sourceSlugForEvent(event, configuredSources);
  const coordinates = mapCoordinatesForEvent(event, sourceSlug, configuredSources);
  return mapsUrl(coordinates ? { ...event, ...coordinates } : event);
};

const excerpt = (value: string | null) => {
  if (!value) return uiText.en.fallbackExcerpt;
  return cleanDisplayText(value);
};

const eventPayloadById = Object.fromEntries(
  visibleCards.map((event) => {
    const localePayload = Object.fromEntries(
      supportedLocales.map((supportedLocale) => {
        const localizedEvent =
          displayEventsByLocale[supportedLocale].find((candidate) => candidate.id === event.id) ??
          permanentEventsByLocale[supportedLocale].find((candidate) => candidate.id === event.id) ??
          event;

        return [
          supportedLocale,
          {
            title: localizedEvent.title,
            dateText: localizedEvent.date_text,
            institutionName: localizedEvent.institution_name,
            excerpt: excerpt(localizedEvent.description),
            mapsUrl: mapsUrlForEvent(localizedEvent),
            googleCalendarUrl: googleCalendarUrl(localizedEvent),
            sourceUrl: localizedEvent.source_url,
            calendarTitle: localizedEvent.title,
            calendarDetails: calendarDetailsFor(localizedEvent),
            calendarLocation: calendarLocationFor(localizedEvent),
          },
        ];
      }),
    );

    return [event.id, localePayload];
  }),
);

const localePayload = {
  events: eventPayloadById,
  meta: Object.fromEntries(
    supportedLocales.map((supportedLocale) => [
      supportedLocale,
      {
        title:
          city === 'kyoto'
            ? uiText[supportedLocale].title
            : `${cityConfig.label} | ${uiText.en.title}`,
        description:
          city === 'kyoto'
            ? uiText[supportedLocale].description
            : uiText[supportedLocale].description
                .replaceAll('Kyōto', cityConfig.label)
                .replaceAll('Kyoto', cityConfig.label)
                .replaceAll('京都', cityConfig.label),
      },
    ]),
  ),
};
const localePayloadJson = JSON.stringify(localePayload).replace(/</g, '\\u003c');
---

<BaseLayout
  city={city}
  cityThemeColor={cityConfig.themeColor}
  locale={locale}
  title={cityMetaTitle}
  description={cityMetaDescription}
  landingActive={true}
>
  <main class="page-shell">
    <Landing
      cityLabel={cityConfig.label}
      brandLabel={cityConfig.brandLabel}
      categories={categories}
      ongoingCount={ongoingEvents.length}
      upcomingCount={upcomingEvents.length}
      slides={landingSlides}
    />
    <div class="content-container" data-content-container data-main-content>
      <section class="events-section" data-events-section>
        <Header categories={categories} city={city} locale={locale} />

        <div class="empty-state empty-state--filtered" data-filter-empty hidden>
          <h3>{copy.noEvents}</h3>
          <p>{copy.unsetFilters}</p>
        </div>

        {
          visibleCards.length === 0 ? (
            <div class="empty-state">
              <h3>{copy.emptyTitle}</h3>
              <p>{copy.emptyDescription}</p>
            </div>
          ) : (
            <>
              <section
                class="event-group"
                data-event-group
                data-event-group-name="ongoing"
                hidden={ongoingEvents.length === 0}
              >
                {ongoingEvents.map((event, index) => (
                  <EventCard
                    event={event}
                    locale={locale}
                    hideTopBorder={index === 0}
                    mapSourceSlug={sourceSlugByEventId.get(event.id)}
                    mapLocationId={mapLocationIdByEventId.get(event.id)}
                    mapsUrl={mapsUrlForEvent(event)}
                    googleCalendarUrl={googleCalendarUrl(event)}
                    excerpt={excerpt(event.description)}
                    beta={isEventBeta(event)}
                  />
                ))}
              </section>

              <div
                class="events-divider"
                data-event-divider
                data-before-group="ongoing"
                data-after-group="upcoming"
                hidden={ongoingEvents.length === 0 || upcomingEvents.length === 0}
              >
                <TimeDivider
                  label={copy.upcoming}
                  readyLabel={copy.getReady}
                  ariaLabel={copy.upcomingEventsAria}
                />
              </div>

              <section
                class="event-group"
                data-event-group
                data-event-group-name="upcoming"
                hidden={upcomingEvents.length === 0}
              >
                {upcomingEvents.map((event, index) => (
                  <EventCard
                    event={event}
                    locale={locale}
                    hideTopBorder={ongoingEvents.length === 0 && index === 0}
                    mapSourceSlug={sourceSlugByEventId.get(event.id)}
                    mapLocationId={mapLocationIdByEventId.get(event.id)}
                    mapsUrl={mapsUrlForEvent(event)}
                    googleCalendarUrl={googleCalendarUrl(event)}
                    excerpt={excerpt(event.description)}
                    beta={isEventBeta(event)}
                  />
                ))}
              </section>

              <div
                class="events-divider"
                data-event-divider
                data-before-group="upcoming"
                data-after-group="permanent"
                hidden={upcomingEvents.length === 0 || permanentEvents.length === 0}
              >
                <TimeDivider
                  label="permanent"
                  readyLabel="permanent"
                  ariaLabel="permanent venues"
                />
              </div>

              <section
                class="event-group"
                data-event-group
                data-event-group-name="permanent"
                hidden={permanentEvents.length === 0}
              >
                {permanentEvents.map((event, index) => (
                  <EventCard
                    event={event}
                    locale={locale}
                    hideTopBorder={
                      ongoingEvents.length === 0 && upcomingEvents.length === 0 && index === 0
                    }
                    mapSourceSlug={sourceSlugByEventId.get(event.id)}
                    mapLocationId={mapLocationIdByEventId.get(event.id)}
                    mapsUrl={mapsUrlForEvent(event)}
                    googleCalendarUrl={googleCalendarUrl(event)}
                    excerpt={excerpt(event.description)}
                    beta={isEventBeta(event)}
                  />
                ))}
              </section>
            </>
          )
        }
        <Footer />
      </section>

      <div
        class="map-resizer"
        data-map-resizer
        role="separator"
        tabindex="0"
        aria-label="Resize map"
        aria-orientation="vertical"
        hidden
        inert
      >
      </div>
      <span class="map-resizer-handle" aria-hidden="true"></span>

      <section class="map-section" id="map-section" data-map-section hidden>
        <GoogleMapCanvas
          cityLabel={cityConfig.label}
          mapCenter={cityConfig.mapCenter}
          sources={mapSources}
        />
      </section>
    </div>
    <script type="application/json" data-locale-payload set:html={localePayloadJson} />
  </main>
</BaseLayout>

<script>
  import { initEventCardReveal } from '../../../scripts/eventCardReveal';
  import { initMapResizer } from '../../../scripts/mapResizer';

  initEventCardReveal();
  initMapResizer();
</script>

<style lang="sass">
  $mobile-breakpoint: 768px

  :global(.page-shell)
    min-height: 100%
    width: 100%
    overflow-x: hidden
    overflow-x: clip

  .section-heading
    display: flex
    justify-content: space-between
    gap: 0.75rem
    align-items: flex-end

    &__count
      margin: 0
      font-size: var(--type-body-size)
      text-transform: uppercase

  .empty-state
    padding: 1.5rem 0

    h3,
    p
      margin: 0

    p
      margin-top: 0.5rem

  .empty-state--filtered
    border-top: 0
    padding-top: 0

  .content-container
    --layout-transition-duration: 260ms
    --layout-transition-ease: cubic-bezier(0.16, 1, 0.3, 1)
    --map-resizer-hit-size: 1rem
    --default-events-panel-size: clamp(400px, 50%, 600px)
    --default-map-panel-size: min(45svh, 24.5rem)
    position: relative
    flex: 1 1 auto
    display: flex
    align-items: stretch
    height: 100%
    min-height: 100%
    width: 100%
    overflow: hidden

  .events-section
    --events-section-gap: 2rem
    flex: 1 1 100%
    height: 100%
    min-height: 0
    min-width: 0
    display: flex
    flex-direction: column
    gap: var(--events-section-gap)
    overflow-x: hidden
    overflow-y: auto
    overscroll-behavior: contain
    scrollbar-width: none
    transition: flex-basis var(--layout-transition-duration) var(--layout-transition-ease), flex-grow var(--layout-transition-duration) var(--layout-transition-ease)
    &::-webkit-scrollbar
      display: none

  .map-section
    flex: 0 1 0
    height: 100%
    min-height: 0
    min-width: 0
    max-width: 0
    display: flex
    flex-direction: column
    overflow: hidden
    opacity: 0
    visibility: hidden
    pointer-events: none
    transition: flex-basis var(--layout-transition-duration) var(--layout-transition-ease), flex-grow var(--layout-transition-duration) var(--layout-transition-ease), max-width var(--layout-transition-duration) var(--layout-transition-ease), max-height var(--layout-transition-duration) var(--layout-transition-ease), opacity 160ms ease-out

    &[hidden]
      display: none

    :global(.map-canvas)
      flex: 1 1 auto
      height: 100%
      min-height: 0

  .content-container[data-map-visible] .events-section
    flex: 0 0 var(--events-panel-size, var(--default-events-panel-size))

  .content-container[data-map-visible] .map-section
    flex: 1 1 0
    max-width: 100%
    opacity: 1
    visibility: visible
    pointer-events: auto

  .content-container[data-map-resizing]
    cursor: col-resize
    user-select: none
    @media screen and (max-width: $mobile-breakpoint)
      cursor: row-resize

    .events-section,
    .map-section
      transition: none

  .map-resizer
    position: relative
    z-index: 20
    flex: 0 0 var(--stroke-width)
    align-self: stretch
    width: var(--stroke-width)
    color: var(--color-green)
    cursor: col-resize
    touch-action: none
    opacity: 0
    visibility: hidden
    overflow: visible
    isolation: isolate
    @media screen and (max-width: $mobile-breakpoint)
      cursor: row-resize

    &[hidden]
      display: none

    &::before
      content: ""
      position: absolute
      top: 0
      bottom: 0
      left: calc((var(--map-resizer-hit-size) - var(--stroke-width)) / -2)
      width: var(--map-resizer-hit-size)
      cursor: col-resize
      @media screen and (max-width: $mobile-breakpoint)
        cursor: row-resize

    &::after
      content: ""
      position: absolute
      top: 0
      bottom: 0
      left: 0
      width: 100%
      background: currentColor
      pointer-events: none

    &:focus-visible
      outline: none

      &::after
        left: calc(var(--stroke-width) * -1)
        width: calc(var(--stroke-width) * 2)

  .content-container[data-map-visible] .map-resizer
    opacity: 1
    visibility: visible

  .map-resizer-handle
    position: absolute
    top: 50%
    left: var(--events-panel-size, var(--default-events-panel-size))
    z-index: 120
    width: 2rem
    height: 2rem
    color: var(--color-green)
    transform: translate(-50%, -50%)
    opacity: 0
    visibility: hidden
    pointer-events: none
    translate: 1px 0
    @media screen and (max-width: $mobile-breakpoint)
      translate: 0 1px

    &::before
      content: ""
      position: absolute
      top: 50%
      left: 50%
      width: 1.25rem
      height: 1.375rem
      transform: translate(-50%, -50%) rotate(90deg)
      background: currentColor
      -webkit-mask: url("/divider.svg") center / contain no-repeat
      mask: url("/divider.svg") center / contain no-repeat

  .content-container[data-map-visible] .map-resizer-handle
    opacity: 1
    visibility: visible

  .map-section[data-map-closing]
    visibility: visible
    pointer-events: none

  .event-group
    display: flex
    flex-direction: column

  .events-divider
    display: block

  @media (max-width: $mobile-breakpoint)
    .content-container
      flex-direction: column
      height: auto
      min-height: 100%
      overflow: visible

      &[data-map-visible] .map-section
        order: -2
        flex: 0 0 var(--map-panel-size, var(--default-map-panel-size))
        max-height: var(--map-panel-size, var(--default-map-panel-size))

      .map-section[data-map-closing]
        order: -2

    .content-container[data-map-visible] .events-section
      flex: 1 1 auto
      min-height: 0

    .events-section
      height: auto
      overflow: visible
      overscroll-behavior: auto

    .content-container[data-map-resizing]
      cursor: row-resize

    .map-section
      flex: 0 0 0
      width: 100%
      max-width: 100%
      max-height: 0

    .map-resizer
      order: -1
      align-self: stretch
      width: 100%
      height: var(--stroke-width)
      cursor: row-resize

      &::before
        left: 0
        right: 0
        top: calc((var(--map-resizer-hit-size) - var(--stroke-width)) / -2)
        bottom: auto
        width: auto
        height: var(--map-resizer-hit-size)
        cursor: row-resize

      &::after
        top: 0
        bottom: auto
        left: 0
        right: 0
        width: auto
        height: 100%
        background: currentColor

      &:focus-visible::after
        top: calc(var(--stroke-width) * -1)
        height: calc(var(--stroke-width) * 2)

    .map-resizer-handle
      top: var(--map-panel-size, var(--default-map-panel-size))
      left: 50%

      &::before
        transform: translate(-50%, -50%)

    .section-heading
      flex-direction: column
      align-items: flex-start
</style>
