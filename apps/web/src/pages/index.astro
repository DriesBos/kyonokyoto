---
import { supabase } from "../lib/supabase";

type EventRow = {
  id: string;
  title: string;
  artist_name: string | null;
  categories: string[];
  date_text: string;
  institution_name: string;
  venue_name: string | null;
  address_text: string | null;
  directions_query: string | null;
  calendar_starts_at: string | null;
  calendar_ends_at: string | null;
  primary_image_url: string | null;
  source_url: string;
  description: string | null;
};

const { data, error } = await supabase
  .from("events")
  .select(
    "id, title, artist_name, categories, date_text, institution_name, venue_name, address_text, directions_query, calendar_starts_at, calendar_ends_at, primary_image_url, source_url, description"
  )
  .eq("status", "published")
  .order("start_date", { ascending: true, nullsFirst: false });

if (error) {
  throw error;
}

const events = (data ?? []) as EventRow[];

const mapsUrl = (event: EventRow) => {
  const query = event.directions_query ?? event.address_text ?? event.venue_name ?? event.institution_name;
  if (/^https?:\/\//i.test(query)) return query;
  return `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(query)}`;
};

const toGoogleCalendarStamp = (value: string) => {
  const date = new Date(value);
  const pad = (part: number) => String(part).padStart(2, "0");

  return [
    date.getUTCFullYear(),
    pad(date.getUTCMonth() + 1),
    pad(date.getUTCDate()),
    "T",
    pad(date.getUTCHours()),
    pad(date.getUTCMinutes()),
    pad(date.getUTCSeconds()),
    "Z",
  ].join("");
};

const calendarUrl = (event: EventRow) => {
  const start = event.calendar_starts_at;
  if (!start) return null;

  const end = event.calendar_ends_at ?? start;
  const details = event.description ?? `${event.institution_name}${event.venue_name ? ` — ${event.venue_name}` : ""}`;
  const location = event.address_text ?? event.venue_name ?? event.institution_name;

  return `https://calendar.google.com/calendar/render?action=TEMPLATE&text=${encodeURIComponent(event.title)}&dates=${toGoogleCalendarStamp(start)}/${toGoogleCalendarStamp(end)}&details=${encodeURIComponent(details)}&location=${encodeURIComponent(location)}`;
};

const excerpt = (value: string | null) => {
  if (!value) return "More details available on the original source page.";
  return value.length > 220 ? `${value.slice(0, 217)}...` : value;
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Kyo no Kyoto</title>
    <meta
      name="description"
      content="A one-page Kyoto cultural calendar for exhibitions, talks, workshops, concerts, and seasonal events."
    />
  </head>
  <body>
    <main class="page-shell">
      <section class="hero">
        <p class="eyebrow">Kyoto Today</p>
        <h1>Kyo no Kyoto</h1>
        <p class="intro">
          A one-page cultural calendar for exhibitions, talks, performances, and seasonal programs happening across Kyoto.
        </p>
      </section>

      <section class="events-section">
        <div class="section-heading">
          <h2>Current Listings</h2>
          <p>{events.length} published event{events.length === 1 ? "" : "s"} in the feed</p>
        </div>

        {
          events.length === 0 ? (
            <div class="empty-state">
              <h3>No published events yet</h3>
              <p>The crawler pipeline is connected. Once events are published, they’ll appear here automatically.</p>
            </div>
          ) : (
            <div class="event-list">
              {events.map((event) => (
                <article class="event-card">
                  {event.primary_image_url ? (
                    <img class="event-image" src={event.primary_image_url} alt={event.title} loading="lazy" />
                  ) : (
                    <div class="event-image placeholder">Kyoto</div>
                  )}

                  <div class="event-body">
                    <div class="meta-row">
                      <span class="institution">{event.institution_name}</span>
                      <span class="date">{event.date_text}</span>
                    </div>

                    <h3>{event.title}</h3>

                    {event.artist_name ? <p class="artist">by {event.artist_name}</p> : null}

                    {event.categories.length > 0 ? (
                      <ul class="category-list">
                        {event.categories.map((category) => (
                          <li>{category}</li>
                        ))}
                      </ul>
                    ) : null}

                    <dl class="info-grid">
                      <div>
                        <dt>Venue</dt>
                        <dd>{event.venue_name ?? event.institution_name}</dd>
                      </div>
                      <div>
                        <dt>Address</dt>
                        <dd>{event.address_text ?? "See source page"}</dd>
                      </div>
                    </dl>

                    <p class="description">{excerpt(event.description)}</p>

                    <div class="actions">
                      <a href={event.source_url} target="_blank" rel="noreferrer">Source</a>
                      <a href={mapsUrl(event)} target="_blank" rel="noreferrer">Directions</a>
                      {calendarUrl(event) ? (
                        <a href={calendarUrl(event)!} target="_blank" rel="noreferrer">Add to Calendar</a>
                      ) : (
                        <span class="disabled-action">Calendar soon</span>
                      )}
                    </div>
                  </div>
                </article>
              ))}
            </div>
          )
        }
      </section>
    </main>
  </body>
</html>

<style>
  :root {
    --bg: #f6f1e8;
    --panel: #fffdf9;
    --ink: #1f1c19;
    --muted: #72685d;
    --line: #d9cfc0;
    --accent: #b74d2c;
    --accent-soft: #f1d8ce;
    --shadow: 0 18px 40px rgba(55, 36, 24, 0.08);
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    font-family: "Iowan Old Style", "Palatino Linotype", "Book Antiqua", Palatino, Georgia, serif;
    background:
      radial-gradient(circle at top left, rgba(183, 77, 44, 0.14), transparent 28rem),
      linear-gradient(180deg, #f3ecdf 0%, var(--bg) 28%, #efe5d6 100%);
    color: var(--ink);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  .page-shell {
    width: min(1120px, calc(100vw - 2rem));
    margin: 0 auto;
    padding: 2rem 0 4rem;
  }

  .hero {
    padding: 2rem 0 2.5rem;
  }

  .eyebrow {
    margin: 0 0 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font: 600 0.8rem/1.2 ui-sans-serif, system-ui, sans-serif;
    color: var(--accent);
  }

  h1 {
    margin: 0;
    font-size: clamp(3rem, 7vw, 5.8rem);
    line-height: 0.96;
    letter-spacing: -0.04em;
  }

  .intro {
    width: min(40rem, 100%);
    margin: 1rem 0 0;
    font-size: 1.08rem;
    line-height: 1.7;
    color: var(--muted);
  }

  .section-heading {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: end;
    margin-bottom: 1.4rem;
  }

  .section-heading h2 {
    margin: 0;
    font-size: 1.7rem;
  }

  .section-heading p {
    margin: 0;
    color: var(--muted);
    font: 500 0.95rem/1.4 ui-sans-serif, system-ui, sans-serif;
  }

  .event-list {
    display: grid;
    gap: 1.2rem;
  }

  .event-card {
    display: grid;
    grid-template-columns: minmax(180px, 280px) 1fr;
    gap: 1.2rem;
    padding: 1rem;
    background: color-mix(in srgb, var(--panel) 85%, white);
    border: 1px solid rgba(114, 104, 93, 0.18);
    border-radius: 1.5rem;
    box-shadow: var(--shadow);
    overflow: hidden;
  }

  .event-image {
    width: 100%;
    height: 100%;
    min-height: 240px;
    object-fit: cover;
    border-radius: 1rem;
    background: #e6ddd0;
  }

  .event-image.placeholder {
    display: grid;
    place-items: center;
    font-size: 2rem;
    letter-spacing: 0.08em;
    color: rgba(31, 28, 25, 0.45);
  }

  .event-body {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    min-width: 0;
  }

  .meta-row {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    font: 600 0.85rem/1.4 ui-sans-serif, system-ui, sans-serif;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .meta-row .institution {
    color: var(--accent);
  }

  h3 {
    margin: 0;
    font-size: clamp(1.7rem, 3vw, 2.35rem);
    line-height: 1.06;
  }

  .artist {
    margin: 0;
    color: var(--muted);
    font-style: italic;
  }

  .category-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .category-list li {
    padding: 0.38rem 0.7rem;
    border-radius: 999px;
    background: var(--accent-soft);
    color: #76311a;
    font: 600 0.78rem/1.1 ui-sans-serif, system-ui, sans-serif;
  }

  .info-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem 1rem;
    margin: 0;
    padding: 0.85rem 0 0;
    border-top: 1px solid var(--line);
  }

  .info-grid dt {
    margin: 0 0 0.2rem;
    color: var(--muted);
    font: 600 0.75rem/1.2 ui-sans-serif, system-ui, sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .info-grid dd {
    margin: 0;
    line-height: 1.45;
  }

  .description {
    margin: 0;
    line-height: 1.7;
    color: #403931;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: auto;
    padding-top: 0.5rem;
  }

  .actions a,
  .actions .disabled-action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.75rem;
    padding: 0 1rem;
    border-radius: 999px;
    border: 1px solid var(--line);
    background: white;
    font: 600 0.9rem/1 ui-sans-serif, system-ui, sans-serif;
  }

  .actions a:first-child {
    background: var(--ink);
    color: white;
    border-color: var(--ink);
  }

  .actions .disabled-action {
    color: var(--muted);
    background: #f1ece4;
  }

  .empty-state {
    padding: 2rem;
    border: 1px dashed var(--line);
    border-radius: 1.2rem;
    background: rgba(255, 255, 255, 0.55);
  }

  .empty-state h3 {
    margin: 0 0 0.5rem;
    font-size: 1.35rem;
  }

  .empty-state p {
    margin: 0;
    color: var(--muted);
  }

  @media (max-width: 760px) {
    .page-shell {
      width: min(100vw - 1rem, 1120px);
      padding-top: 1rem;
    }

    .section-heading {
      flex-direction: column;
      align-items: start;
    }

    .event-card {
      grid-template-columns: 1fr;
    }

    .event-image {
      min-height: 220px;
    }

    .meta-row,
    .info-grid {
      grid-template-columns: 1fr;
    }

    .meta-row {
      flex-direction: column;
    }
  }
</style>
