---
import { CITY_COOKIE, normalizeCity } from '../lib/cities';
import { LOCALE_COOKIE, resolveLocale } from '../lib/i18n';

export const prerender = false;

const locale = resolveLocale({
  cookieLocale: Astro.cookies.get(LOCALE_COOKIE)?.value,
  acceptLanguage: Astro.request.headers.get('accept-language'),
});
const city = normalizeCity(Astro.cookies.get(CITY_COOKIE)?.value) ?? 'kyoto';

return new Response(null, {
  status: 302,
  headers: {
    Location: `/${city}/${locale}/`,
    'Cache-Control': 'no-store',
    'Netlify-CDN-Cache-Control': 'no-store',
    Vary: 'Cookie, Accept-Language',
  },
});
---
