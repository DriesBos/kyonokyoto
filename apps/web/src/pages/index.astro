---
import EventCard from "../components/EventCard.astro";
import Header from "../components/Header.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import PageEdgeStrokes from "../components/PageEdgeStrokes.astro";
import { supabase } from "../lib/supabase";

type EventRow = {
  id: string;
  title: string;
  artist_name: string | null;
  categories: string[];
  date_text: string;
  institution_name: string;
  venue_name: string | null;
  address_text: string | null;
  directions_query: string | null;
  calendar_starts_at: string | null;
  calendar_ends_at: string | null;
  primary_image_url: string | null;
  image_urls: string[] | null;
  source_url: string;
  description: string | null;
};

const { data, error } = await supabase
  .from("events")
  .select(
    "id, title, artist_name, categories, date_text, institution_name, venue_name, address_text, directions_query, calendar_starts_at, calendar_ends_at, primary_image_url, image_urls, source_url, description"
  )
  .eq("status", "published")
  .order("start_date", { ascending: true, nullsFirst: false });

if (error) {
  throw error;
}

const events = (data ?? []) as EventRow[];

const normalizeCategory = (value: string) =>
  value
    .toLowerCase()
    .trim()
    .replace(/&/g, "and")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "");

const titleCaseCategory = (value: string) =>
  value
    .trim()
    .toLowerCase()
    .split(/\s+/)
    .filter(Boolean)
    .map((word) => word.charAt(0).toUpperCase() + word.slice(1))
    .join(" ");

const preferredCategoryOrder = [
  "exhibition",
  "museum",
  "event",
  "music",
  "mingei",
  "ceramics",
  "workshop",
  "festival",
  "fair",
];

const categoryMap = new Map<string, string>();

for (const event of events) {
  for (const category of event.categories) {
    const slug = normalizeCategory(category);
    if (!slug || categoryMap.has(slug)) continue;
    categoryMap.set(slug, titleCaseCategory(category));
  }
}

const categories = [...categoryMap.entries()]
  .map(([slug, label]) => ({ slug, label: label.toLowerCase() }))
  .sort((a, b) => {
    const aIndex = preferredCategoryOrder.indexOf(a.slug);
    const bIndex = preferredCategoryOrder.indexOf(b.slug);

    if (aIndex === -1 && bIndex === -1) return a.label.localeCompare(b.label);
    if (aIndex === -1) return 1;
    if (bIndex === -1) return -1;
    return aIndex - bIndex;
  });

const mapsUrl = (event: EventRow) => {
  const query = event.directions_query ?? event.address_text ?? event.venue_name ?? event.institution_name;
  if (/^https?:\/\//i.test(query)) return query;
  return `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(query)}`;
};

const toGoogleCalendarStamp = (value: string) => {
  const date = new Date(value);
  const pad = (part: number) => String(part).padStart(2, "0");

  return [
    date.getUTCFullYear(),
    pad(date.getUTCMonth() + 1),
    pad(date.getUTCDate()),
    "T",
    pad(date.getUTCHours()),
    pad(date.getUTCMinutes()),
    pad(date.getUTCSeconds()),
    "Z",
  ].join("");
};

const calendarUrl = (event: EventRow) => {
  const start = event.calendar_starts_at;
  if (!start) return null;

  const end = event.calendar_ends_at ?? start;
  const details = event.description ?? `${event.institution_name}${event.venue_name ? ` — ${event.venue_name}` : ""}`;
  const location = event.address_text ?? event.venue_name ?? event.institution_name;

  return `https://calendar.google.com/calendar/render?action=TEMPLATE&text=${encodeURIComponent(event.title)}&dates=${toGoogleCalendarStamp(start)}/${toGoogleCalendarStamp(end)}&details=${encodeURIComponent(details)}&location=${encodeURIComponent(location)}`;
};

const excerpt = (value: string | null) => {
  if (!value) return "More details available on the original source page.";
  return value.length > 220 ? `${value.slice(0, 217)}...` : value;
};

const formatEventDate = (value: string) => {
  const match = value.match(/(\d{4})-(\d{2})-(\d{2})/);
  if (!match) return value;

  const [, year, month, day] = match;
  return `${year}-${month}-${day}`;
};

const formattedEvents = events.map((event) => ({
  ...event,
  date_text: formatEventDate(event.date_text),
}));
---

<BaseLayout>
  <main class="page-shell">
    <PageEdgeStrokes position="top" />

    <Header categories={categories} />

    <section class="events-section">

      <div class="empty-state empty-state--filtered" data-filter-empty hidden>
        <h3>No events in this category</h3>
        <p>Choose another filter or click the active one again to show everything.</p>
      </div>

      {
        events.length === 0 ? (
          <div class="empty-state">
            <h3>No published events yet</h3>
            <p>The crawler pipeline is connected. Once events are published, they’ll appear here automatically.</p>
          </div>
        ) : (
          <div class="event-list">
            {formattedEvents.map((event) => (
              <EventCard
                event={event}
                mapsUrl={mapsUrl(event)}
                calendarUrl={calendarUrl(event)}
                excerpt={excerpt(event.description)}
              />
            ))}
          </div>
        )
      }
    </section>

    <PageEdgeStrokes position="bottom" lines={24} />
  </main>
</BaseLayout>
