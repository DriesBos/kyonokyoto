---
import EventCard from "../../components/EventCard.astro";
import Footer from "../../components/Footer.astro";
import GoogleMapCanvas from "../../components/GoogleMapCanvas.astro";
import Header from "../../components/Header.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import TimeDivider from "../../components/TimeDivider.astro";
import sourcesPayload from "../../../../../data/sources/kyoto-sources.json";
import type { AppLocale } from "../../lib/i18n";
import { normalizeLocale, supportedLocales, uiText } from "../../lib/i18n";
import { calendarDetailsFor, calendarLocationFor, cleanDisplayText, googleCalendarUrl, mapsUrl } from "../../lib/calendar";
import { displayEventsByLocale as buildDisplayEventsByLocale, fetchPublishedEvents } from "../../lib/events";
import {
  categoriesForEvents,
  configuredSourcesFrom,
  mapSourcesForEvents,
  sourceSlugForEvent,
  type SourceConfig,
} from "../../lib/sources";

export const prerender = false;

Astro.response.headers.set(
  "Cache-Control",
  "public, max-age=60, s-maxage=300, stale-while-revalidate=86400"
);
Astro.response.headers.set(
  "Netlify-CDN-Cache-Control",
  "public, s-maxage=300, stale-while-revalidate=86400"
);

const routeLocale = normalizeLocale(Astro.params.locale);
if (!routeLocale) return Astro.redirect("/en/", 302);
if (Astro.params.locale !== routeLocale) return Astro.redirect(`/${routeLocale}/`, 302);

const locale = routeLocale;
const copy = uiText.en;
const metaCopy = uiText[locale];

const configuredSources = configuredSourcesFrom(sourcesPayload.sources as SourceConfig[]);
const events = await fetchPublishedEvents();
const displayEventsByLocale = buildDisplayEventsByLocale({
  events,
  configuredSources,
  supportedLocales,
});
const displayEvents = displayEventsByLocale[locale];
const categories = categoriesForEvents(displayEvents);
const ongoingEvents = displayEvents.filter((event) => event.timing === "ongoing");
const upcomingEvents = displayEvents.filter((event) => event.timing === "upcoming");
const sourceSlugByEventId = new Map(displayEvents.map((event) => [event.id, sourceSlugForEvent(event, configuredSources)]));
const mapSources = mapSourcesForEvents(displayEvents, sourceSlugByEventId, configuredSources);

const excerpt = (value: string | null, activeLocale: AppLocale = locale) => {
  if (!value) return uiText[activeLocale].fallbackExcerpt;
  return cleanDisplayText(value);
};

const eventPayloadById = Object.fromEntries(
  displayEvents.map((event) => {
    const localePayload = Object.fromEntries(
      supportedLocales.map((supportedLocale) => {
        const localizedEvent = displayEventsByLocale[supportedLocale].find((candidate) => candidate.id === event.id) ?? event;

        return [
          supportedLocale,
          {
            title: localizedEvent.title,
            dateText: localizedEvent.date_text,
            institutionName: localizedEvent.institution_name,
            excerpt: excerpt(localizedEvent.description, supportedLocale),
            mapsUrl: mapsUrl(localizedEvent),
            googleCalendarUrl: googleCalendarUrl(localizedEvent),
            sourceUrl: localizedEvent.source_url,
            calendarTitle: localizedEvent.title,
            calendarDetails: calendarDetailsFor(localizedEvent),
            calendarLocation: calendarLocationFor(localizedEvent),
          },
        ];
      })
    );

    return [event.id, localePayload];
  })
);

const localePayload = {
  events: eventPayloadById,
  meta: Object.fromEntries(
    supportedLocales.map((supportedLocale) => [
      supportedLocale,
      {
        title: uiText[supportedLocale].title,
        description: uiText[supportedLocale].description,
      },
    ])
  ),
};
const localePayloadJson = JSON.stringify(localePayload).replace(/</g, "\\u003c");

---

<BaseLayout locale={locale} title={metaCopy.title} description={metaCopy.description}>
  <main class="page-shell">
    <div class="content-container" data-content-container>
      <section class="events-section" data-events-section>
        <Header categories={categories} locale={locale} />

        <div class="empty-state empty-state--filtered" data-filter-empty hidden>
          <h3>{copy.noEvents}</h3>
          <p>{copy.unsetFilters}</p>
        </div>

        {
          displayEvents.length === 0 ? (
            <div class="empty-state">
              <h3>{copy.emptyTitle}</h3>
              <p>{copy.emptyDescription}</p>
            </div>
          ) : (
            <>
              <section class="event-group" data-event-group data-event-group-name="ongoing" hidden={ongoingEvents.length === 0}>
                {ongoingEvents.map((event, index) => (
                  <EventCard
                    event={event}
                    locale={locale}
                    hideTopBorder={index === 0}
                    mapSourceSlug={sourceSlugByEventId.get(event.id)}
                    mapsUrl={mapsUrl(event)}
                    googleCalendarUrl={googleCalendarUrl(event)}
                    excerpt={excerpt(event.description)}
                  />
                ))}
              </section>

              <div class="events-divider" data-event-divider hidden={ongoingEvents.length === 0 || upcomingEvents.length === 0}>
                <TimeDivider label={copy.upcoming} readyLabel={copy.getReady} ariaLabel={copy.upcomingEventsAria} />
              </div>

              <section class="event-group" data-event-group data-event-group-name="upcoming" hidden={upcomingEvents.length === 0}>
                {upcomingEvents.map((event, index) => (
                  <EventCard
                    event={event}
                    locale={locale}
                    hideTopBorder={ongoingEvents.length === 0 && index === 0}
                    mapSourceSlug={sourceSlugByEventId.get(event.id)}
                    mapsUrl={mapsUrl(event)}
                    googleCalendarUrl={googleCalendarUrl(event)}
                    excerpt={excerpt(event.description)}
                  />
                ))}
              </section>
            </>
          )
        }
        <Footer />
      </section>

      <section class="map-section" id="map-section" data-map-section hidden>
        <GoogleMapCanvas sources={mapSources} />
      </section>
    </div>
    <script type="application/json" data-locale-payload set:html={localePayloadJson} />
  </main>
</BaseLayout>

<script>
  import { initEventCardReveal } from "../../scripts/eventCardReveal";

  initEventCardReveal();
</script>

<style lang="sass">
  $mobile-breakpoint: 768px

  :global(.page-shell)
    height: 100svh
    width: 100%
    overflow: hidden

  .section-heading
    display: flex
    justify-content: space-between
    gap: 0.75rem
    align-items: flex-end

    &__count
      margin: 0
      font-size: var(--type-body-size)
      text-transform: uppercase

  .empty-state
    padding: 1.5rem 0

    h3,
    p
      margin: 0

    p
      margin-top: 0.5rem

  .empty-state--filtered
    border-top: 0
    padding-top: 0

  .content-container
    --layout-transition-duration: 260ms
    --layout-transition-ease: cubic-bezier(0.16, 1, 0.3, 1)
    display: flex
    align-items: stretch
    height: 100%
    width: 100%
    overflow: hidden

  .events-section
    --events-section-gap: 2rem
    flex: 1 1 100%
    height: 100%
    min-height: 0
    min-width: 0
    display: flex
    flex-direction: column
    gap: var(--events-section-gap)
    overflow-x: hidden
    overflow-y: auto
    overscroll-behavior: contain
    scrollbar-width: none
    transition: flex-basis var(--layout-transition-duration) var(--layout-transition-ease), flex-grow var(--layout-transition-duration) var(--layout-transition-ease)
    &::-webkit-scrollbar
      display: none
      
  .map-section
    flex: 0 1 0
    height: 100%
    min-height: 0
    min-width: 0
    max-width: 0
    display: flex
    flex-direction: column
    overflow: hidden
    opacity: 0
    visibility: hidden
    pointer-events: none
    transition: flex-basis var(--layout-transition-duration) var(--layout-transition-ease), flex-grow var(--layout-transition-duration) var(--layout-transition-ease), max-width var(--layout-transition-duration) var(--layout-transition-ease), max-height var(--layout-transition-duration) var(--layout-transition-ease), opacity 160ms ease-out

    &[hidden]
      display: none

    :global(.map-canvas)
      flex: 1 1 auto
      height: 100%
      min-height: 0

  .content-container[data-map-visible] .events-section
    flex: 0 0 clamp(400px, 50%, 600px)

  .content-container[data-map-visible] .map-section
    flex: 1 1 0
    max-width: 100%
    opacity: 1
    visibility: visible
    pointer-events: auto

  .map-section[data-map-closing]
    visibility: visible
    pointer-events: none

  .event-group
    display: flex
    flex-direction: column

  .events-divider
    display: block

  @media (max-width: $mobile-breakpoint)
    .content-container
      flex-direction: column

      &[data-map-visible] .map-section
        order: -1
        flex: 0 0 min(45svh, 24.5rem)
        max-height: min(45svh, 24.5rem)

      .map-section[data-map-closing]
        order: -1

    .content-container[data-map-visible] .events-section
      flex: 1 1 auto
      min-height: 0

    .map-section
      flex: 0 0 0
      width: 100%
      max-width: 100%
      max-height: 0

    .section-heading
      flex-direction: column
      align-items: flex-start
</style>
