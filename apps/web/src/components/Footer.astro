---
import Icon from './Icon.astro';

type Props = {
  cityLabel?: string;
  scrollTopLabel?: string;
};

const { cityLabel = 'Kyōtō', scrollTopLabel = 'Scroll to top' } = Astro.props;
---

<footer class="site-footer" data-site-footer>
  <div class="site-footer__content page-edge-strokes__footer">
    <div class="site-footer__left page-edge-strokes__left">
      <div class="site-footer__credit page-edge-strokes__credit">
        <p>
          Site by{' '}
          <a href="https://driesbos.com" target="_blank" rel="noopener noreferrer"> Dries Bos </a>
        </p>
      </div>
      <div class="site-footer__note page-edge-strokes__note">
        <p>Enjoy {cityLabel} Culture</p>
      </div>
    </div>
    <button
      class="site-footer__scroll-top page-edge-strokes__scroll-top"
      type="button"
      aria-label={scrollTopLabel}
      data-scroll-top-button
    >
      <Icon name="arrow-long" rotation="top" />
    </button>
  </div>
</footer>

<script>
  import { scrollRootFor } from '../scripts/scrollRoot';

  type ScrollTopWindow = Window &
    typeof globalThis & {
      __siteFooterScrollTopBound?: boolean;
    };

  const scrollTopWindow = window as ScrollTopWindow;

  if (!scrollTopWindow.__siteFooterScrollTopBound) {
    document.addEventListener('click', (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;

      const button = target.closest('[data-scroll-top-button]');
      if (!(button instanceof HTMLElement)) return;

      event.preventDefault();
      const scrollRoot = scrollRootFor(button);
      if (scrollRoot) {
        scrollRoot.scrollTo({ top: 0, behavior: 'smooth' });
        return;
      }

      window.scrollTo({ top: 0, behavior: 'smooth' });
    });

    scrollTopWindow.__siteFooterScrollTopBound = true;
  }
</script>

<style lang="sass">
  .site-footer
    position: relative
    flex: 0 0 50vh
    width: 100%
    height: 50vh
    padding-bottom: calc(var(--page-padding-y) + env(safe-area-inset-bottom))
    background: repeating-linear-gradient(to bottom, var(--stroke) 0 var(--stroke-width), transparent var(--stroke-width) calc(var(--stroke-width) + var(--stroke-gap)))

  .site-footer__content
    position: absolute
    left: 0
    right: 0
    bottom: calc(var(--page-padding-y) + env(safe-area-inset-bottom))
    z-index: 1
    display: flex
    flex-direction: row
    align-items: flex-end
    justify-content: space-between
    gap: var(--control-gap)
    max-width: 100%

  .site-footer__left
    display: flex
    flex-direction: row
    flex-wrap: nowrap
    align-items: flex-end
    gap: 4rem

    @media (max-width: 425px)
      width: 100%
      gap: 1.5rem

  .site-footer__credit,
  .site-footer__note
    display: inline-flex
    margin: 0
    padding: 0.25rem var(--control-gap)
    padding-bottom: 0
    background: var(--color-beige)
    color: var(--color-green)
    font-size: var(--type-body-size)
    line-height: 1

    p
      margin: 0

    a
      display: inline-flex
      align-items: center
      justify-content: flex-start
      gap: 4px
      padding: 0 1px 3px
      border-bottom: var(--stroke-width) solid var(--stroke)
      text-decoration: none

  .site-footer__credit
    padding-left: var(--page-padding-x)
    padding-right: var(--control-gap)

  .site-footer__note
    padding-bottom: 0.25rem

  .site-footer__scroll-top
    display: grid
    place-items: center
    width: calc(var(--icon-size) + 1rem)
    height: calc(var(--icon-size) * 2 + 1rem)
    margin: 0
    padding: 0.25rem
    border: 0
    appearance: none
    -webkit-tap-highlight-color: transparent
    background: var(--color-beige) !important
    z-index: 1
    color: currentColor
    cursor: var(--dot-cursor)

    &:hover,
    &:active,
    &:focus-visible
      outline: none
      background: var(--color-beige)

    &:focus-visible
      box-shadow: inset 0 0 0 var(--stroke-width) var(--stroke)
</style>
