---
type Props = {
  position: "top" | "bottom";
  lines?: number;
};

const { position, lines = 4 } = Astro.props;
const strokeCount = Math.max(0, Math.floor(lines));
---

<div class:list={["page-edge-strokes", `page-edge-strokes--${position}`]} aria-hidden="true">
  {Array.from({ length: strokeCount }).map(() => <span></span>)}
</div>
