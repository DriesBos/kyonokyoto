---
type Props = {
  position: 'top' | 'bottom';
  lines?: number;
};

const { position, lines = 4 } = Astro.props;
const strokeCount = Math.max(0, Math.floor(lines));
---

<div class:list={['page-edge-strokes', `page-edge-strokes--${position}`]}>
  {Array.from({ length: strokeCount }).map(() => <span aria-hidden="true" />)}
</div>

<style lang="sass">
  .page-edge-strokes
    position: relative
    display: grid
    gap: var(--stroke-gap)

    span
      display: block
      width: 100%
      border-top: var(--stroke-width) solid var(--stroke)

  .page-edge-strokes--top
    padding-top: 0
    margin-bottom: 0

  .page-edge-strokes--bottom
    padding-bottom: 0
</style>
