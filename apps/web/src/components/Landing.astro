---
import Icon from './Icon.astro';
import Logo from './Logo.astro';
import type { LandingSlide } from '../lib/landingSlides';

type Props = {
  cityLabel?: string;
  categories: {
    label: string;
    slug: string;
  }[];
  ongoingCount: number;
  upcomingCount: number;
  slides?: LandingSlide[];
};

const { cityLabel = 'Kyoto', categories, ongoingCount, upcomingCount, slides = [] } = Astro.props;
const landingLabel = `What's on in ${cityLabel}`;
const slidesJson = JSON.stringify(slides).replace(/</g, '\\u003c');
---

<section class="landing" data-landing aria-label={`Kyō-no-Kyōto: ${landingLabel}`}>
  {
    slides.length > 0 ? (
      <>
        <span class="landing__background" data-landing-slider aria-hidden="true">
          <span class="landing__slides" data-landing-slider-slides />
          <span class="landing__shutters" data-landing-slider-shutters />
        </span>
        <script type="application/json" data-landing-slider-payload set:html={slidesJson} />
      </>
    ) : null
  }
  <button
    class="landing__button"
    type="button"
    data-landing-trigger
    aria-label={`Enter ${landingLabel}`}
  >
    <span class="landing__content">
      <span class="landing__logo" aria-hidden="true">
        <Logo />
      </span>
      <span class="landing__bottom landing__bottom--label">{landingLabel}</span>
      <span class="landing__bottom landing__bottom--arrow" aria-hidden="true">
        <Icon name="arrow-long" rotation="bottom" />
      </span>
      <span class="landing__categories" aria-hidden="true">
        {categories.map((category) => <span>#{category.label}</span>)}
      </span>
      <span class="landing__counts" aria-hidden="true">
        <span>{ongoingCount} ongoing</span>
        <span>{upcomingCount} upcoming</span>
      </span>
    </span>
  </button>
</section>

<script>
  import { initLandingScroll } from '../scripts/landingScroll';
  import { initLandingSlider } from '../scripts/landingSlider';

  initLandingScroll();
  initLandingSlider();
</script>

<style lang="sass">
  $mobile-breakpoint: 768px

  .landing
    --landing-logo-height: 48px
    --landing-arrow-bottom: 2rem
    --landing-arrow-height: 50px
    --landing-slider-row-height: 10rem
    position: relative
    flex: 0 0 100lvh
    height: 100lvh
    min-height: 100lvh
    width: 100%
    background: var(--color-green)
    color: var(--color-beige)
    overflow: hidden
    align-items: flex-start
    isolation: isolate

  .landing__button
    position: relative
    z-index: 2
    display: block
    width: 100%
    height: 100%
    padding: 0
    border: 0
    background: transparent
    color: inherit
    appearance: none
    -webkit-tap-highlight-color: transparent

  .landing__background
    position: absolute
    z-index: 0
    inset: 0
    display: block
    overflow: hidden
    pointer-events: none

  .landing__slides,
  .landing__shutters,
  :global(.landing__slide),
  :global(.landing__slide img)
    position: absolute
    inset: 0
    display: block

  .landing__slides
    z-index: 0

  :global(.landing__slide)
    opacity: 0

  :global(.landing__slide[data-active])
    opacity: 1

  :global(.landing__slide img)
    width: 100%
    height: 100%
    object-fit: cover
    object-position: center

  .landing__shutters
    z-index: 1
    display: flex
    flex-direction: column
    align-items: stretch
    justify-content: flex-start

  :global(.landing__shutter-row)
    position: relative
    flex: 0 0 var(--landing-slider-row-height)
    width: 100%
    overflow: hidden

  :global(.landing__shutter-fill)
    position: absolute
    top: 0
    left: 0
    right: 0
    height: 100%
    background: var(--color-green)
    will-change: height

  :global(.landing__shutter-fill[data-fill-origin='bottom'])
    top: auto
    bottom: 0

  .landing__content
    position: relative
    display: block
    width: 100%
    height: 100svh
    min-height: 100svh

  .landing__logo
    position: absolute
    top: 50%
    left: 50%
    width: 251px
    height: var(--landing-logo-height)
    transform: translate(-50%, -50%)
    user-select: none

    :global(svg)
      display: block
      width: 251px
      height: var(--landing-logo-height)

  .landing__bottom
    position: absolute
    bottom: var(--landing-arrow-bottom)
    display: flex
    align-items: center
    justify-content: center
    color: inherit
    user-select: none

  .landing__bottom--label
    left: 50%
    bottom: auto
    top: calc((50svh + (var(--landing-logo-height) / 2) + (100svh - var(--landing-arrow-bottom) - var(--landing-arrow-height))) / 2)
    transform: translate(-50%, -50%)
    font-size: 1.125rem
    line-height: 1
    white-space: nowrap
    user-select: none
    @media (max-width: $mobile-breakpoint)
      font-size: 1.25rem

  .landing__bottom--arrow
    left: 50%
    width: 25px
    height: var(--landing-arrow-height)
    transform: translateX(-50%)
    user-select: none

    :global(.icon)
      --icon-width: 25px
      --icon-height: var(--landing-arrow-height)

  .landing__categories
    position: absolute
    left: 2rem
    bottom: 2rem
    display: flex
    flex-wrap: wrap
    align-items: center
    gap: 0.5rem 1rem
    max-width: 33%
    font-size: 1.125rem
    line-height: 1
    text-align: left
    user-select: none

  .landing__counts
    position: absolute
    right: 2rem
    bottom: 2rem
    display: flex
    align-items: center
    gap: 2rem
    font-size: 1.125rem
    line-height: 1
    white-space: nowrap
    user-select: none
    @media (max-width: $mobile-breakpoint)
      font-size: 1.25rem

  @media (max-width: $mobile-breakpoint)
    .landing
      --landing-slider-row-height: 6rem

    .landing__categories,
    .landing__counts
      display: none
</style>
