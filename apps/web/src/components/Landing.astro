---
import Icon from './Icon.astro';
import Logo from './Logo.astro';

type Props = {
  cityLabel?: string;
  categories: {
    label: string;
    slug: string;
  }[];
  ongoingCount: number;
  upcomingCount: number;
};

const { cityLabel = 'Kyoto', categories, ongoingCount, upcomingCount } = Astro.props;
const landingLabel = `What's on in ${cityLabel}`;
---

<section class="landing" data-landing aria-label={`Kyō-no-Kyōto: ${landingLabel}`}>
  <button
    class="landing__button"
    type="button"
    data-landing-trigger
    aria-label={`Enter ${landingLabel}`}
  >
    <span class="landing__content">
      <span class="landing__logo" aria-hidden="true">
        <Logo />
      </span>
      <span class="landing__bottom landing__bottom--label">{landingLabel}</span>
      <span class="landing__bottom landing__bottom--arrow" aria-hidden="true">
        <Icon name="arrow-long" rotation="bottom" />
      </span>
      <span class="landing__categories" aria-hidden="true">
        {categories.map((category) => <span>#{category.label}</span>)}
      </span>
      <span class="landing__counts" aria-hidden="true">
        <span>{ongoingCount} ongoing</span>
        <span>{upcomingCount} upcoming</span>
      </span>
    </span>
  </button>
</section>

<script>
  import { initLandingScroll } from '../scripts/landingScroll';

  initLandingScroll();
</script>

<style lang="sass">
  $mobile-breakpoint: 768px

  .landing
    --landing-logo-height: 48px
    --landing-arrow-bottom: 2rem
    --landing-arrow-height: 50px
    flex: 0 0 100lvh
    height: 100lvh
    min-height: 100lvh
    width: 100%
    background: var(--color-green)
    color: var(--color-beige)
    overflow: hidden
    align-items: flex-start

  .landing__button
    position: relative
    display: block
    width: 100%
    height: 100%
    padding: 0
    border: 0
    background: transparent
    color: inherit
    appearance: none
    -webkit-tap-highlight-color: transparent

  .landing__content
    position: relative
    display: block
    width: 100%
    height: 100svh
    min-height: 100svh

  .landing__logo
    position: absolute
    top: 50%
    left: 50%
    width: 251px
    height: var(--landing-logo-height)
    transform: translate(-50%, -50%)
    user-select: none

    :global(svg)
      display: block
      width: 251px
      height: var(--landing-logo-height)

  .landing__bottom
    position: absolute
    bottom: var(--landing-arrow-bottom)
    display: flex
    align-items: center
    justify-content: center
    color: inherit
    user-select: none

  .landing__bottom--label
    left: 50%
    bottom: auto
    top: calc((50svh + (var(--landing-logo-height) / 2) + (100svh - var(--landing-arrow-bottom) - var(--landing-arrow-height))) / 2)
    transform: translate(-50%, -50%)
    font-size: 1.125rem
    line-height: 1
    white-space: nowrap
    user-select: none
    @media (max-width: $mobile-breakpoint)
      font-size: 1.25rem

  .landing__bottom--arrow
    left: 50%
    width: 25px
    height: var(--landing-arrow-height)
    transform: translateX(-50%)
    user-select: none

    :global(.icon)
      --icon-width: 25px
      --icon-height: var(--landing-arrow-height)

  .landing__categories
    position: absolute
    left: 2rem
    bottom: 2rem
    display: flex
    flex-wrap: wrap
    align-items: center
    gap: 0.5rem 1rem
    max-width: 33%
    font-size: 1.125rem
    line-height: 1
    text-align: left
    user-select: none

  .landing__counts
    position: absolute
    right: 2rem
    bottom: 2rem
    display: flex
    align-items: center
    gap: 2rem
    font-size: 1.125rem
    line-height: 1
    white-space: nowrap
    user-select: none
    @media (max-width: $mobile-breakpoint)
      font-size: 1.25rem

  @media (max-width: $mobile-breakpoint)
    .landing__categories,
    .landing__counts
      display: none
</style>
