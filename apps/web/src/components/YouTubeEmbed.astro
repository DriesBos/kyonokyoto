---
import { buildYouTubeEmbedSrc } from '../lib/youtubeEmbed';

type Props = {
  videoId: string;
  title: string;
  eager?: boolean;
};

const { videoId, title, eager = false } = Astro.props;
const src = buildYouTubeEmbedSrc(videoId, { origin: Astro.url.origin });
---

<span class="youtube-embed" data-youtube-embed data-youtube-ambient data-youtube-video-id={videoId}>
  <iframe
    class="youtube-embed__frame"
    src={eager ? src : undefined}
    data-youtube-frame
    data-youtube-src={src}
    title={title}
    loading={eager ? 'eager' : 'lazy'}
    allow="autoplay; encrypted-media; picture-in-picture"
    referrerpolicy="strict-origin-when-cross-origin"
    tabindex="-1"></iframe>
</span>

<script>
  import { initAmbientYouTubeEmbeds } from '../scripts/youtubeAmbient';

  initAmbientYouTubeEmbeds();
</script>

<style lang="sass">
  .youtube-embed
    position: relative
    display: block
    width: calc(var(--event-card-media-row-height-current) * 16 / 9)
    height: var(--event-card-media-row-height-current)
    overflow: hidden
    background: var(--stroke)
    pointer-events: none

    &__frame
      position: absolute
      inset: 0
      width: 100%
      height: 100%
      border: 0
      pointer-events: none
</style>
