---
type Props = {
  label?: string;
  readyLabel?: string;
  ariaLabel?: string;
};

const {
  label = 'upcoming',
  readyLabel = 'get ready!',
  ariaLabel = 'upcoming events',
} = Astro.props;
const repeatedTrackText = (value: string) =>
  Array.from({ length: 20 }, () => `${value}\u00a0\u00a0↓\u00a0\u00a0`).join('');
const tracks = [
  {
    label,
    className: 'time-divider__track--right',
    direction: 'right',
    travel: 16,
  },
  {
    label: readyLabel,
    className: 'time-divider__track--right',
    direction: 'right',
    start: -28,
    end: -10,
    travel: 14,
  },
  {
    label,
    className: 'time-divider__track--right',
    direction: 'right',
    travel: 12,
  },
  {
    label,
    className: 'time-divider__track--right',
    direction: 'right',
    travel: 14,
    mobileOnly: true,
  },
  {
    label,
    className: 'time-divider__track--right',
    direction: 'right',
    travel: 17,
    mobileOnly: true,
  },
  {
    label,
    className: 'time-divider__track--right',
    direction: 'right',
    travel: 15,
    mobileOnly: true,
  },
  {
    label,
    className: 'time-divider__track--right',
    direction: 'right',
    travel: 19,
    mobileOnly: true,
    mobileHidden: true,
  },
  {
    label,
    className: 'time-divider__track--right',
    direction: 'right',
    travel: 11,
    mobileOnly: true,
    mobileHidden: true,
  },
];
---

<astro-time-divider class="time-divider" aria-label={ariaLabel} data-time-divider>
  <div class="time-divider__viewport" data-time-divider-viewport>
    <div class="time-divider__scroller" aria-hidden="true">
      {
        tracks.map((track) => (
          <div
            class:list={[
              'time-divider__track',
              track.className,
              {
                'time-divider__track--mobile-extra': track.mobileOnly,
                'time-divider__track--mobile-hidden': track.mobileHidden,
              },
            ]}
            data-time-divider-track
            data-direction={track.direction}
            data-travel={'travel' in track ? track.travel : undefined}
            data-start={'start' in track ? track.start : undefined}
            data-end={'end' in track ? track.end : undefined}
          >
            <div class="time-divider__group">{repeatedTrackText(track.label)}</div>
            <div class="time-divider__group">{repeatedTrackText(track.label)}</div>
          </div>
        ))
      }
    </div>
  </div>
</astro-time-divider>

<script>
  import { scrollRootFor } from '../scripts/scrollRoot';
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const trackSelector = '[data-time-divider-track]';
  const scrollScrubSeconds = 0.33;
  const layoutSettledFrameCount = 3;
  let dividerInstanceCount = 0;
  let scrollTriggerRefreshFrame = 0;

  const nextDividerInstanceId = () => {
    dividerInstanceCount += 1;
    return `time-divider-${dividerInstanceCount}`;
  };

  const scheduleScrollTriggerRefresh = () => {
    if (scrollTriggerRefreshFrame) {
      window.cancelAnimationFrame(scrollTriggerRefreshFrame);
    }

    scrollTriggerRefreshFrame = window.requestAnimationFrame(() => {
      scrollTriggerRefreshFrame = 0;
      ScrollTrigger.refresh();
    });
  };

  const afterLayoutSettled = (callback: () => void, frameCount = layoutSettledFrameCount) => {
    const tick = (remainingFrames: number) => {
      if (remainingFrames <= 0) {
        callback();
        return;
      }

      window.requestAnimationFrame(() => tick(remainingFrames - 1));
    };

    tick(frameCount);
  };

  const parseDistance = (track: HTMLElement) => {
    const direction = track.dataset.direction === 'right' ? 'right' : 'left';
    const travel = Number.parseFloat(track.dataset.travel || '50');
    const distance = Number.isFinite(travel) ? travel : 50;
    const customStart = Number.parseFloat(track.dataset.start || '');
    const customEnd = Number.parseFloat(track.dataset.end || '');
    const defaultStartX = direction === 'right' ? -distance : 0;
    const defaultEndX = direction === 'right' ? 0 : -distance;

    return {
      startX: Number.isFinite(customStart) ? customStart : defaultStartX,
      endX: Number.isFinite(customEnd) ? customEnd : defaultEndX,
    };
  };

  class AstroTimeDivider extends HTMLElement {
    buildFrame = 0;
    buildToken = 0;
    context: gsap.Context | null = null;
    instanceId = '';
    refreshFrame = 0;
    releaseFontReady: (() => void) | null = null;
    resizeObserver: ResizeObserver | null = null;
    lastMeasuredWidth: number | null = null;

    handleFilterUpdate = () => {
      this.scheduleBuild();
    };

    handleResize = () => {
      const currentWidth = window.innerWidth;
      if (this.lastMeasuredWidth !== null && currentWidth === this.lastMeasuredWidth) {
        return;
      }

      this.scheduleBuild();
    };

    handleLoad = () => {
      this.scheduleBuild();
    };

    connectedCallback() {
      if (!this.instanceId) {
        this.instanceId = nextDividerInstanceId();
        this.dataset.timeDividerInstance = this.instanceId;
      }

      document.addEventListener('event-filter:updated', this.handleFilterUpdate);
      window.addEventListener('resize', this.handleResize);
      window.addEventListener('load', this.handleLoad, { once: true });

      const fontsReady = document.fonts?.ready;
      if (fontsReady) {
        let active = true;
        this.releaseFontReady = () => {
          active = false;
        };

        fontsReady
          .then(() => {
            if (!active) return;
            this.scheduleBuild();
          })
          .catch(() => {});
      }

      this.scheduleBuild();
    }

    disconnectedCallback() {
      document.removeEventListener('event-filter:updated', this.handleFilterUpdate);
      window.removeEventListener('resize', this.handleResize);
      window.removeEventListener('load', this.handleLoad);
      this.releaseFontReady?.();
      this.releaseFontReady = null;

      if (this.buildFrame) {
        window.cancelAnimationFrame(this.buildFrame);
        this.buildFrame = 0;
      }

      if (this.refreshFrame) {
        window.cancelAnimationFrame(this.refreshFrame);
        this.refreshFrame = 0;
      }

      this.cleanupAnimations();
    }

    cleanupAnimations() {
      this.resizeObserver?.disconnect();
      this.resizeObserver = null;
      this.context?.revert();
      this.context = null;

      if (!this.instanceId) return;

      ScrollTrigger.getAll().forEach((trigger) => {
        if (trigger.trigger === this || trigger.vars.id === this.instanceId) {
          trigger.kill();
        }
      });
    }

    scheduleRefresh() {
      if (this.refreshFrame) {
        window.cancelAnimationFrame(this.refreshFrame);
      }

      this.refreshFrame = window.requestAnimationFrame(() => {
        this.refreshFrame = 0;
        if (!this.context) return;
        ScrollTrigger.refresh();
      });
    }

    observeLayout(scrollRoot: HTMLElement | null) {
      this.resizeObserver?.disconnect();
      this.resizeObserver = null;

      if (!('ResizeObserver' in window)) return;

      this.resizeObserver = new ResizeObserver(() => {
        this.scheduleRefresh();
      });
      this.resizeObserver.observe(this);

      if (scrollRoot) {
        this.resizeObserver.observe(scrollRoot);
      }
    }

    scheduleBuild() {
      const token = this.buildToken + 1;
      this.buildToken = token;

      if (this.buildFrame) {
        window.cancelAnimationFrame(this.buildFrame);
      }

      this.buildFrame = window.requestAnimationFrame(() => {
        this.buildFrame = 0;
        afterLayoutSettled(() => {
          if (token !== this.buildToken) return;
          this.buildAnimations();
        });
      });
    }

    isRenderable() {
      return !this.closest('[hidden]') && this.getClientRects().length > 0 && this.offsetHeight > 0;
    }

    getScrollRoot() {
      return scrollRootFor(this);
    }

    buildAnimations() {
      this.cleanupAnimations();

      if (!this.isConnected || !this.isRenderable()) return;

      this.context = gsap.context(() => {
        const tracks = gsap.utils
          .toArray<HTMLElement>(trackSelector, this)
          .filter((track) => track.getClientRects().length > 0);

        if (!tracks.length) return;

        const scrollRoot = this.getScrollRoot();
        const scrollTriggerConfig: ScrollTrigger.Vars = {
          id: this.instanceId,
          trigger: this,
          start: 'top bottom',
          end: 'bottom top',
          scrub: scrollScrubSeconds,
          invalidateOnRefresh: true,
        };

        if (scrollRoot) {
          scrollTriggerConfig.scroller = scrollRoot;
        }

        const timeline = gsap.timeline({
          defaults: { ease: 'none' },
          scrollTrigger: scrollTriggerConfig,
        });

        tracks.forEach((track) => {
          const { startX, endX } = parseDistance(track);
          timeline.fromTo(track, { xPercent: startX }, { xPercent: endX, duration: 1 }, 0);
        });

        this.observeLayout(scrollRoot);
        scheduleScrollTriggerRefresh();
        this.lastMeasuredWidth = window.innerWidth;
      }, this);
    }
  }

  if (!customElements.get('astro-time-divider')) {
    customElements.define('astro-time-divider', AstroTimeDivider);
  }
</script>

<style lang="sass">
  $mobile-breakpoint: 768px

  .time-divider
    display: block
    position: relative
    width: 100%
    overflow: clip

    &__viewport
      position: relative
      display: flex
      align-items: center
      overflow: hidden

    &__scroller
      display: flex
      flex-direction: column
      justify-content: center
      gap: 3rem
      width: 100%
      overflow: hidden
      padding: 10vh 0

    &__track
      display: flex
      width: max-content
      gap: 2px

      @media (hover: hover) and (pointer: fine)
        will-change: transform

      &--mobile-extra
        display: none

    &__group
      flex: 0 0 auto
      padding-right: 4px
      font-size: var(--type-title-size)
      line-height: 1
      white-space: nowrap
      letter-spacing: 0

  @media (max-width: $mobile-breakpoint)
    .time-divider
      &__scroller
        gap: 2rem

      &__track--mobile-extra
        display: flex

      &__track--mobile-hidden
        display: none
</style>
