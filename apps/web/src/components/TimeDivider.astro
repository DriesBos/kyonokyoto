---
import Icon from "./Icon.astro";

type Props = {
  label?: string;
};

const { label = "Upcoming" } = Astro.props;
const items = Array.from({ length: 25 });
const tracks = [
  {
    className: "time-divider__track--right",
    direction: "right",
    travel: 46,
  },
  {
    className: "time-divider__track--right",
    direction: "right",
    travel: 52,
  },
  {
    className: "time-divider__track--right",
    direction: "right",
    travel: 39,
  },
  {
    className: "time-divider__track--right",
    direction: "right",
    travel: 44,
    mobileOnly: true,
  },
  {
    className: "time-divider__track--right",
    direction: "right",
    travel: 57,
    mobileOnly: true,
  },
  {
    className: "time-divider__track--right",
    direction: "right",
    travel: 35,
    mobileOnly: true,
  },
  {
    className: "time-divider__track--right",
    direction: "right",
    travel: 49,
    mobileOnly: true,
  },
  {
    className: "time-divider__track--right",
    direction: "right",
    travel: 61,
    mobileOnly: true,
  },
  {
    className: "time-divider__track--right",
    direction: "right",
    travel: 42,
    mobileOnly: true,
  },
  {
    className: "time-divider__track--right",
    direction: "right",
    travel: 54,
    mobileOnly: true,
  },
  {
    className: "time-divider__track--right",
    direction: "right",
    travel: 37,
    mobileOnly: true,
  },
  {
    className: "time-divider__track--right",
    direction: "right",
    travel: 48,
    mobileOnly: true,
  },
];
---

<div class="time-divider" aria-label={`${label} events`} data-time-divider>
  <div class="time-divider__scroller" aria-hidden="true">
    {tracks.map((track) => (
      <div
        class:list={["time-divider__track", track.className, { "time-divider__track--mobile-extra": track.mobileOnly }]}
        data-time-divider-track
        data-direction={track.direction}
        data-travel={track.travel}
      >
        <div class="time-divider__group">
          {items.map(() => (
            <>
              <span>{label}</span>
              <Icon name="arrow" rotation="bottom" class="time-divider__icon" />
            </>
          ))}
        </div>
        <div class="time-divider__group">
          {items.map(() => (
            <>
              <span>{label}</span>
              <Icon name="arrow" rotation="bottom" class="time-divider__icon" />
            </>
          ))}
        </div>
      </div>
    ))}
  </div>
</div>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  type TimeDividerWindow = Window &
    typeof globalThis & {
      __timeDividerBound?: boolean;
      __timeDividerCleanup?: () => void;
    };

  const dividerWindow = window as TimeDividerWindow;
  const dividerSelector = "[data-time-divider]";
  const trackSelector = "[data-time-divider-track]";
  const scrollDistanceMultiplier = 5;
  const scrollScrubSeconds = 0.33;

  const cleanupTimeDividers = () => {
    dividerWindow.__timeDividerCleanup?.();
    dividerWindow.__timeDividerCleanup = undefined;
  };

  const scheduleScrollTriggerRefresh = () => {
    window.requestAnimationFrame(() => {
      ScrollTrigger.refresh();
    });
  };

  const buildTimeDividerAnimations = () => {
    cleanupTimeDividers();

    const dividers = gsap.utils.toArray<HTMLElement>(dividerSelector);
    const contexts = dividers.map((divider) =>
      gsap.context(() => {
        const tracks = gsap.utils.toArray<HTMLElement>(trackSelector, divider);

        tracks.forEach((track) => {
          const direction = track.dataset.direction === "right" ? "right" : "left";
          const travel = Number.parseFloat(track.dataset.travel || "50");
          const distance = Number.isFinite(travel) ? travel : 50;
          const startX = direction === "right" ? -distance : 0;
          const endX = direction === "right" ? 0 : -distance;

          gsap.fromTo(
            track,
            { xPercent: startX },
            {
              xPercent: endX,
              ease: "none",
              scrollTrigger: {
                trigger: divider,
                start: "top bottom",
                end: () => `+=${(divider.offsetHeight + window.innerHeight) * scrollDistanceMultiplier}`,
                scrub: scrollScrubSeconds,
                invalidateOnRefresh: true,
              },
            },
          );
        });
      }, divider),
    );

    dividerWindow.__timeDividerCleanup = () => {
      contexts.forEach((context) => context.revert());
    };

    scheduleScrollTriggerRefresh();
  };

  buildTimeDividerAnimations();

  if (!dividerWindow.__timeDividerBound) {
    document.addEventListener("astro:page-load", buildTimeDividerAnimations);
    document.addEventListener("astro:before-swap", cleanupTimeDividers);
    document.addEventListener("event-filter:updated", scheduleScrollTriggerRefresh);
    window.addEventListener("load", scheduleScrollTriggerRefresh, { once: true });
    window.addEventListener("resize", scheduleScrollTriggerRefresh);
    dividerWindow.__timeDividerBound = true;
  }
</script>
