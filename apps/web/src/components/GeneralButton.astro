---
import Icon from "./Icon.astro";

type IconName = "arrow" | "arrow-long" | "calendar";
type IconDirection = "top" | "right" | "bottom" | "left";

type Props = {
  label: string;
  icon?: IconName;
  iconRotation?: IconDirection;
  href?: string;
  pressed?: boolean;
  type?: "button" | "submit" | "reset";
  value?: string;
  name?: string;
  class?: string;
  showDot?: boolean;
  disabled?: boolean;
  target?: string;
  rel?: string;
  dataCategory?: string;
  dataCategoryButton?: boolean;
  dataTiming?: string;
  dataTimingButton?: boolean;
  dataFilterButton?: boolean;
  dataAmbientSoundButton?: boolean;
  ariaControls?: string;
};

const {
  label,
  icon,
  iconRotation,
  href,
  pressed,
  type = "button",
  value,
  name,
  class: className,
  showDot = false,
  disabled = false,
  target,
  rel,
  dataCategory,
  dataCategoryButton = false,
  dataTiming,
  dataTimingButton = false,
  dataFilterButton = false,
  dataAmbientSoundButton = false,
  ariaControls,
  ...rest
} = Astro.props;

const classes = ["general-button", disabled && "general-button--disabled", className];
---

{
  href && !disabled ? (
    <a
      class:list={classes}
      href={href}
      target={target}
      rel={rel}
      data-category={dataCategory}
      data-category-button={dataCategoryButton ? "" : undefined}
      data-timing={dataTiming}
      data-timing-button={dataTimingButton ? "" : undefined}
      data-filter-button={dataFilterButton ? "" : undefined}
      data-ambient-sound-button={dataAmbientSoundButton ? "" : undefined}
      aria-pressed={typeof pressed === "boolean" ? String(pressed) : undefined}
      aria-controls={ariaControls}
      {...rest}
    >
      <span class="general-button__label">{label}</span>
      {icon ? <Icon name={icon} rotation={iconRotation} class="general-button__icon" /> : null}
      {showDot ? <span class="general-button__dot" aria-hidden="true"></span> : null}
    </a>
  ) : disabled ? (
    <span
      class:list={classes}
      aria-disabled="true"
      data-category={dataCategory}
      data-category-button={dataCategoryButton ? "" : undefined}
      data-timing={dataTiming}
      data-timing-button={dataTimingButton ? "" : undefined}
      data-filter-button={dataFilterButton ? "" : undefined}
      data-ambient-sound-button={dataAmbientSoundButton ? "" : undefined}
      aria-pressed={typeof pressed === "boolean" ? String(pressed) : undefined}
      aria-controls={ariaControls}
      {...rest}
    >
      <span class="general-button__label">{label}</span>
      {icon ? <Icon name={icon} rotation={iconRotation} class="general-button__icon" /> : null}
      {showDot ? <span class="general-button__dot" aria-hidden="true"></span> : null}
    </span>
  ) : (
    <button
      class:list={classes}
      type={type}
      value={value}
      name={name}
      data-category={dataCategory}
      data-category-button={dataCategoryButton ? "" : undefined}
      data-timing={dataTiming}
      data-timing-button={dataTimingButton ? "" : undefined}
      data-filter-button={dataFilterButton ? "" : undefined}
      data-ambient-sound-button={dataAmbientSoundButton ? "" : undefined}
      aria-pressed={typeof pressed === "boolean" ? String(pressed) : undefined}
      aria-controls={ariaControls}
      {...rest}
    >
      <span class="general-button__label">{label}</span>
      {icon ? <Icon name={icon} rotation={iconRotation} class="general-button__icon" /> : null}
      {showDot ? <span class="general-button__dot" aria-hidden="true"></span> : null}
    </button>
  )
}

<script>
  if (!window.__generalButtonDotBound) {
    const buttonSelector = ".general-button";
    const dotSelector = ".general-button__dot";
    const pressedStateBeforeClick = new WeakMap();

    const setButtonDotPosition = (button, clientX, clientY) => {
      const rect = button.getBoundingClientRect();
      button.style.setProperty("--general-button-dot-left", `${clientX - rect.left - button.clientLeft}px`);
      button.style.setProperty("--general-button-dot-top", `${clientY - rect.top - button.clientTop}px`);
    };

    const playAmbientInteractionSound = (clientX, velocity = 0.62) => {
      document.dispatchEvent(
        new CustomEvent("ambient-sound:interaction", {
          detail: {
            viewportX: clientX / Math.max(1, window.innerWidth),
            velocity,
          },
        })
      );
    };

    document.addEventListener("pointerdown", (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;

      const button = target.closest(buttonSelector);
      if (!(button instanceof HTMLElement)) return;
      if (!button.querySelector(dotSelector)) return;

      pressedStateBeforeClick.set(button, button.getAttribute("aria-pressed") === "true");
      setButtonDotPosition(button, event.clientX, event.clientY);
    });

    document.addEventListener("click", (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;

      const button = target.closest(buttonSelector);
      if (!(button instanceof HTMLElement)) return;
      if (!button.querySelector(dotSelector)) return;

      const wasPressed = pressedStateBeforeClick.get(button) === true;
      pressedStateBeforeClick.delete(button);

      window.requestAnimationFrame(() => {
        if (wasPressed || button.getAttribute("aria-pressed") !== "true") return;

        playAmbientInteractionSound(event.clientX, button.hasAttribute("data-ambient-sound-button") ? 0.78 : 0.62);
      });
    });

    window.__generalButtonDotBound = true;
  }
</script>
