---
import Icon from "./Icon.astro";

type IconName = "arrow" | "arrow-long" | "calendar" | "exit" | "map";
type IconDirection = "top" | "right" | "bottom" | "left";

type Props = {
  label: string;
  icon?: IconName;
  iconRotation?: IconDirection;
  href?: string;
  pressed?: boolean;
  type?: "button" | "submit" | "reset";
  value?: string;
  name?: string;
  class?: string;
  showDot?: boolean;
  disabled?: boolean;
  target?: string;
  rel?: string;
  dataCategory?: string;
  dataCategoryButton?: boolean;
  dataTiming?: string;
  dataTimingButton?: boolean;
  dataFilterButton?: boolean;
  ariaControls?: string;
};

const {
  label,
  icon,
  iconRotation,
  href,
  pressed,
  type = "button",
  value,
  name,
  class: className,
  showDot = false,
  disabled = false,
  target,
  rel,
  dataCategory,
  dataCategoryButton = false,
  dataTiming,
  dataTimingButton = false,
  dataFilterButton = false,
  ariaControls,
  ...rest
} = Astro.props;

const classes = ["general-button", disabled && "general-button--disabled", className];
---

{
  href && !disabled ? (
    <a
      class:list={classes}
      href={href}
      target={target}
      rel={rel}
      data-category={dataCategory}
      data-category-button={dataCategoryButton ? "" : undefined}
      data-timing={dataTiming}
      data-timing-button={dataTimingButton ? "" : undefined}
      data-filter-button={dataFilterButton ? "" : undefined}
      aria-pressed={typeof pressed === "boolean" ? String(pressed) : undefined}
      aria-controls={ariaControls}
      {...rest}
    >
      <span class="general-button__label">{label}</span>
      {icon ? <Icon name={icon} rotation={iconRotation} class="general-button__icon" /> : null}
      {showDot ? <span class="general-button__dot" aria-hidden="true"></span> : null}
    </a>
  ) : disabled ? (
    <span
      class:list={classes}
      aria-disabled="true"
      data-category={dataCategory}
      data-category-button={dataCategoryButton ? "" : undefined}
      data-timing={dataTiming}
      data-timing-button={dataTimingButton ? "" : undefined}
      data-filter-button={dataFilterButton ? "" : undefined}
      aria-pressed={typeof pressed === "boolean" ? String(pressed) : undefined}
      aria-controls={ariaControls}
      {...rest}
    >
      <span class="general-button__label">{label}</span>
      {icon ? <Icon name={icon} rotation={iconRotation} class="general-button__icon" /> : null}
      {showDot ? <span class="general-button__dot" aria-hidden="true"></span> : null}
    </span>
  ) : (
    <button
      class:list={classes}
      type={type}
      value={value}
      name={name}
      data-category={dataCategory}
      data-category-button={dataCategoryButton ? "" : undefined}
      data-timing={dataTiming}
      data-timing-button={dataTimingButton ? "" : undefined}
      data-filter-button={dataFilterButton ? "" : undefined}
      aria-pressed={typeof pressed === "boolean" ? String(pressed) : undefined}
      aria-controls={ariaControls}
      {...rest}
    >
      <span class="general-button__label">{label}</span>
      {icon ? <Icon name={icon} rotation={iconRotation} class="general-button__icon" /> : null}
      {showDot ? <span class="general-button__dot" aria-hidden="true"></span> : null}
    </button>
  )
}

<script>
  if (!window.__generalButtonDotBound) {
    const buttonSelector = ".general-button";
    const dotSelector = ".general-button__dot";

    const randomBetween = (min, max) => min + Math.random() * (max - min);

    const setOrganicDotShape = (target) => {
      const variant = Math.floor(Math.random() * 3) + 1;
      target.style.setProperty("--dot-mask", `var(--dot-mask-${variant})`);
      target.style.setProperty("--dot-rotation", `${randomBetween(-18, 18).toFixed(2)}deg`);
      target.style.setProperty("--dot-scale-x", randomBetween(0.94, 1.06).toFixed(3));
      target.style.setProperty("--dot-scale-y", randomBetween(0.96, 1.08).toFixed(3));
    };

    const setButtonDotPosition = (button, clientX, clientY) => {
      const rect = button.getBoundingClientRect();
      button.style.setProperty("--general-button-dot-left", `${clientX - rect.left - button.clientLeft}px`);
      button.style.setProperty("--general-button-dot-top", `${clientY - rect.top - button.clientTop}px`);
      setOrganicDotShape(button);
    };

    document.addEventListener("pointerdown", (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;

      const button = target.closest(buttonSelector);
      if (!(button instanceof HTMLElement)) return;
      if (!button.querySelector(dotSelector)) return;

      setButtonDotPosition(button, event.clientX, event.clientY);
    });

    window.__generalButtonDotBound = true;
  }
</script>

<style lang="sass">
  .general-button
    position: relative
    isolation: isolate
    display: inline-flex
    align-items: center
    justify-content: flex-start
    gap: 4px
    padding: calc(var(--stroke-width) + 3px) calc(var(--control-gap) / 2) 0
    border: 0
    appearance: none
    -webkit-tap-highlight-color: transparent
    background: transparent
    color: currentColor
    font-size: var(--type-button-size)
    letter-spacing: var(--type-body-letter-spacing)
    line-height: 1
    cursor: var(--dot-cursor)
    pointer-events: auto
    overflow: visible

    &::before
      content: ""
      position: absolute
      top: 0
      left: calc(var(--control-gap) / 2)
      right: calc(var(--control-gap) / 2)
      border-top: var(--stroke-width) solid var(--stroke)
      pointer-events: none

    &:hover,
    &:active,
    &:focus,
    &:focus-visible
      outline: none
      background: transparent

    &[aria-pressed='true'] .general-button__dot
      opacity: 1
      overflow: visible

    :global(.general-button__icon)
      position: relative
      z-index: 1
      --icon-size: 1em

  .general-button--disabled
    opacity: 0.55
    cursor: var(--dot-cursor)

  .general-button__label
    position: relative
    z-index: 1
    display: inline-block
    text-transform: lowercase
    overflow: visible

  .general-button__dot
    position: absolute
    z-index: 0
    left: var(--general-button-dot-left, 50%)
    top: var(--general-button-dot-top, 50%)
    width: var(--dot-button)
    height: var(--dot-button)
    background: var(--color-pink)
    mask: var(--dot-mask) center / contain no-repeat
    -webkit-mask: var(--dot-mask) center / contain no-repeat
    opacity: 0
    transform: translate(-50%, -50%) rotate(var(--dot-rotation)) scaleX(var(--dot-scale-x)) scaleY(var(--dot-scale-y))
    transform-origin: center
    transition: opacity 140ms ease
</style>
