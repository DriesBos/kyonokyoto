---
import Icon from "./Icon.astro";

type IconName = "arrow" | "arrow-long" | "calendar" | "exit" | "map" | "star";
type IconDirection = "top" | "right" | "bottom" | "left";
type Edge = "first" | "last";
type VerticalPadding = "none" | "full";

type Props = {
  label: string;
  icon?: IconName;
  iconRotation?: IconDirection;
  href?: string;
  pressed?: boolean;
  type?: "button" | "submit" | "reset";
  value?: string;
  name?: string;
  class?: string;
  showDot?: boolean;
  disabled?: boolean;
  edge?: Edge;
  verticalPadding?: VerticalPadding;
  target?: string;
  rel?: string;
  dataCategory?: string;
  dataCategoryButton?: boolean;
  dataTiming?: string;
  dataTimingButton?: boolean;
  dataFilterButton?: boolean;
  dataStarredButton?: boolean;
  ariaControls?: string;
};

const {
  label,
  icon,
  iconRotation,
  href,
  pressed,
  type = "button",
  value,
  name,
  class: className,
  showDot = false,
  disabled = false,
  edge,
  verticalPadding = "none",
  target,
  rel,
  dataCategory,
  dataCategoryButton = false,
  dataTiming,
  dataTimingButton = false,
  dataFilterButton = false,
  dataStarredButton = false,
  ariaControls,
  ...rest
} = Astro.props;

const classes = [
  "general-button",
  disabled && "general-button--disabled",
  edge && `general-button--edge-${edge}`,
  verticalPadding !== "none" && `general-button--vertical-${verticalPadding}`,
  className,
];
---

{
  href && !disabled ? (
    <a
      class:list={classes}
      href={href}
      target={target}
      rel={rel}
      data-category={dataCategory}
      data-category-button={dataCategoryButton ? "" : undefined}
      data-timing={dataTiming}
      data-timing-button={dataTimingButton ? "" : undefined}
      data-filter-button={dataFilterButton ? "" : undefined}
      data-starred-button={dataStarredButton ? "" : undefined}
      aria-pressed={typeof pressed === "boolean" ? String(pressed) : undefined}
      aria-controls={ariaControls}
      {...rest}
    >
      <span class="general-button__content">
        <span class="general-button__label">{label}</span>
        {icon ? <Icon name={icon} rotation={iconRotation} class="general-button__icon" /> : null}
      </span>
      {showDot ? <span class="general-button__dot" aria-hidden="true"></span> : null}
    </a>
  ) : disabled ? (
    <span
      class:list={classes}
      aria-disabled="true"
      data-category={dataCategory}
      data-category-button={dataCategoryButton ? "" : undefined}
      data-timing={dataTiming}
      data-timing-button={dataTimingButton ? "" : undefined}
      data-filter-button={dataFilterButton ? "" : undefined}
      data-starred-button={dataStarredButton ? "" : undefined}
      aria-pressed={typeof pressed === "boolean" ? String(pressed) : undefined}
      aria-controls={ariaControls}
      {...rest}
    >
      <span class="general-button__content">
        <span class="general-button__label">{label}</span>
        {icon ? <Icon name={icon} rotation={iconRotation} class="general-button__icon" /> : null}
      </span>
      {showDot ? <span class="general-button__dot" aria-hidden="true"></span> : null}
    </span>
  ) : (
    <button
      class:list={classes}
      type={type}
      value={value}
      name={name}
      data-category={dataCategory}
      data-category-button={dataCategoryButton ? "" : undefined}
      data-timing={dataTiming}
      data-timing-button={dataTimingButton ? "" : undefined}
      data-filter-button={dataFilterButton ? "" : undefined}
      data-starred-button={dataStarredButton ? "" : undefined}
      aria-pressed={typeof pressed === "boolean" ? String(pressed) : undefined}
      aria-controls={ariaControls}
      {...rest}
    >
      <span class="general-button__content">
        <span class="general-button__label">{label}</span>
        {icon ? <Icon name={icon} rotation={iconRotation} class="general-button__icon" /> : null}
      </span>
      {showDot ? <span class="general-button__dot" aria-hidden="true"></span> : null}
    </button>
  )
}

<script>
  import { initGeneralButtonDot } from "../scripts/generalButtonDot";

  initGeneralButtonDot();
</script>

<style lang="sass">
  .general-button
    position: relative
    isolation: isolate
    display: inline-flex
    align-items: center
    justify-content: flex-start
    padding: 0
    border: 0
    appearance: none
    -webkit-tap-highlight-color: transparent
    background: transparent
    color: currentColor
    font-size: var(--type-button-size)
    letter-spacing: var(--type-body-letter-spacing)
    line-height: 1
    cursor: var(--dot-cursor)
    pointer-events: auto
    overflow: visible

    &:hover,
    &:active,
    &:focus,
    &:focus-visible
      outline: none
      background: transparent

    &[aria-pressed='true'] .general-button__dot
      opacity: 1
      overflow: visible

    :global(.general-button__icon)
      position: relative
      z-index: 1
      --icon-size: 1em

  .general-button--disabled
    opacity: 0.55
    cursor: var(--dot-cursor)

  .general-button--edge-first
    padding-left: var(--page-padding-x)

  .general-button--edge-last
    padding-right: var(--page-padding-x)

  .general-button--vertical-full
    padding-top: 0.5rem
    padding-bottom: 0.5rem

  .general-button__content
    position: relative
    z-index: 1
    display: inline-flex
    align-items: center
    justify-content: flex-start
    gap: 4px
    padding: calc(var(--stroke-width) + 3px) calc(var(--control-gap) / 2) 0
    overflow: visible

    &::before
      content: ""
      position: absolute
      top: 0
      left: calc(var(--control-gap) / 2)
      right: calc(var(--control-gap) / 2)
      border-top: var(--stroke-width) solid var(--stroke)
      pointer-events: none

  .general-button__label
    position: relative
    z-index: 1
    display: inline-block
    text-transform: lowercase
    overflow: visible

  .general-button__dot
    position: absolute
    z-index: 0
    left: var(--general-button-dot-left, 50%)
    top: var(--general-button-dot-top, 50%)
    width: var(--dot-button)
    height: var(--dot-button)
    background: var(--color-pink)
    mask: var(--dot-mask) center / contain no-repeat
    -webkit-mask: var(--dot-mask) center / contain no-repeat
    opacity: 0
    transform: translate(-50%, -50%) rotate(var(--dot-rotation)) scaleX(var(--dot-scale-x)) scaleY(var(--dot-scale-y))
    transform-origin: center
    transition: opacity 140ms ease
</style>
