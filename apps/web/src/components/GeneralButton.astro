---
type Props = {
  label: string;
  href?: string;
  pressed?: boolean;
  type?: "button" | "submit" | "reset";
  value?: string;
  name?: string;
  class?: string;
  showDot?: boolean;
  disabled?: boolean;
  target?: string;
  rel?: string;
  dataCategory?: string;
  dataCategoryButton?: boolean;
  dataTiming?: string;
  dataTimingButton?: boolean;
  dataFilterButton?: boolean;
  ariaControls?: string;
};

const {
  label,
  href,
  pressed,
  type = "button",
  value,
  name,
  class: className,
  showDot = false,
  disabled = false,
  target,
  rel,
  dataCategory,
  dataCategoryButton = false,
  dataTiming,
  dataTimingButton = false,
  dataFilterButton = false,
  ariaControls,
  ...rest
} = Astro.props;

const classes = ["general-button", disabled && "general-button--disabled", className];
---

{
  href && !disabled ? (
    <a
      class:list={classes}
      href={href}
      target={target}
      rel={rel}
      data-category={dataCategory}
      data-category-button={dataCategoryButton ? "" : undefined}
      data-timing={dataTiming}
      data-timing-button={dataTimingButton ? "" : undefined}
      data-filter-button={dataFilterButton ? "" : undefined}
      aria-pressed={typeof pressed === "boolean" ? String(pressed) : undefined}
      aria-controls={ariaControls}
      {...rest}
    >
      <span class="general-button__label">{label}</span>
      {showDot ? <span class="general-button__dot" aria-hidden="true"></span> : null}
    </a>
  ) : disabled ? (
    <span
      class:list={classes}
      aria-disabled="true"
      data-category={dataCategory}
      data-category-button={dataCategoryButton ? "" : undefined}
      data-timing={dataTiming}
      data-timing-button={dataTimingButton ? "" : undefined}
      data-filter-button={dataFilterButton ? "" : undefined}
      aria-pressed={typeof pressed === "boolean" ? String(pressed) : undefined}
      aria-controls={ariaControls}
      {...rest}
    >
      <span class="general-button__label">{label}</span>
      {showDot ? <span class="general-button__dot" aria-hidden="true"></span> : null}
    </span>
  ) : (
    <button
      class:list={classes}
      type={type}
      value={value}
      name={name}
      data-category={dataCategory}
      data-category-button={dataCategoryButton ? "" : undefined}
      data-timing={dataTiming}
      data-timing-button={dataTimingButton ? "" : undefined}
      data-filter-button={dataFilterButton ? "" : undefined}
      aria-pressed={typeof pressed === "boolean" ? String(pressed) : undefined}
      aria-controls={ariaControls}
      {...rest}
    >
      <span class="general-button__label">{label}</span>
      {showDot ? <span class="general-button__dot" aria-hidden="true"></span> : null}
    </button>
  )
}

<script>
  if (!window.__generalButtonDotBound) {
    const buttonSelector = ".general-button";
    const dotSelector = ".general-button__dot";

    const setButtonDotPosition = (button, clientX, clientY) => {
      const rect = button.getBoundingClientRect();
      button.style.setProperty("--general-button-dot-left", `${clientX - rect.left - button.clientLeft}px`);
      button.style.setProperty("--general-button-dot-top", `${clientY - rect.top - button.clientTop}px`);
    };

    document.addEventListener("pointerdown", (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;

      const button = target.closest(buttonSelector);
      if (!(button instanceof HTMLElement)) return;
      if (!button.querySelector(dotSelector)) return;

      setButtonDotPosition(button, event.clientX, event.clientY);
    });

    window.__generalButtonDotBound = true;
  }
</script>
