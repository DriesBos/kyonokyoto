---
import GeneralButton from "./GeneralButton.astro";
import type { AppLocale } from "../lib/i18n";
import { uiText } from "../lib/i18n";
import { calendarDetailsFor, calendarLocationFor } from "../lib/calendar";

type EventRow = {
  id: string;
  title: string;
  categories: string[];
  date_text: string;
  timing?: "ongoing" | "upcoming" | "past";
  institution_name: string;
  venue_name: string | null;
  address_text: string | null;
  directions_query: string | null;
  calendar_starts_at: string | null;
  calendar_ends_at: string | null;
  primary_image_url: string | null;
  image_urls: string[] | null;
  source_url: string;
  description: string | null;
};

type Props = {
  event: EventRow;
  locale?: AppLocale;
  mapSourceSlug?: string | null;
  mapsUrl: string;
  googleCalendarUrl: string | null;
  excerpt: string;
  hideTopBorder?: boolean;
};

const { event, locale = "en", mapSourceSlug, mapsUrl, googleCalendarUrl, excerpt, hideTopBorder = false } = Astro.props;
const copy = uiText[locale];

const normalizeCategory = (value: string) =>
  value
    .toLowerCase()
    .trim()
    .replace(/&/g, "and")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "");

const categorySlugs = event.categories.map(normalizeCategory);
const maxImagesPerCard = 3;
const imageUrls = (event.image_urls ?? []).filter(Boolean).slice(0, maxImagesPerCard);
const images = imageUrls.length > 0 ? imageUrls : event.primary_image_url ? [event.primary_image_url] : [];
const desktopImageHeightRem = 10;
const mobileImageHeightRem = 6;
const desktopImageHeightActiveRem = 20;
const mobileImageHeightActiveRem = 10;
const calendarStartDate = event.calendar_starts_at?.slice(0, 10) ?? "";
const calendarEndDate = event.calendar_ends_at?.slice(0, 10) ?? "";
const calendarDetails = calendarDetailsFor(event);
const calendarLocation = calendarLocationFor(event);
---

<article
  class="event-card"
  data-event-card
  data-event-card-toggle
  data-reveal-state="pending"
  data-event-id={event.id}
  data-map-source-slug={mapSourceSlug ?? undefined}
  data-active="false"
  data-timing={event.timing}
  data-categories={categorySlugs.join("|")}
  data-hide-top-border={hideTopBorder ? "" : undefined}
  style={`--event-card-media-row-height-desktop: ${desktopImageHeightRem}rem; --event-card-media-row-height-mobile: ${mobileImageHeightRem}rem; --event-card-media-row-height-active-desktop: ${desktopImageHeightActiveRem}rem; --event-card-media-row-height-active-mobile: ${mobileImageHeightActiveRem}rem;`}
  role="button"
  tabindex="0"
  aria-pressed="false"
>
  <button class="event-card__star" type="button" data-event-star-toggle aria-label="Star event" aria-pressed="false">
    <svg class="event-card__star-icon" viewBox="0 0 25 25" aria-hidden="true">
      <path class="event-card__star-ring" d="M12.5 1.75L15.77 8.38L23.08 9.45L17.79 14.6L19.04 21.88L12.5 18.44L5.96 21.88L7.21 14.6L1.92 9.45L9.23 8.38L12.5 1.75Z" />
      <path class="event-card__star-ring event-card__star-ring--second" d="M12.5 1.75L15.77 8.38L23.08 9.45L17.79 14.6L19.04 21.88L12.5 18.44L5.96 21.88L7.21 14.6L1.92 9.45L9.23 8.38L12.5 1.75Z" />
      <path class="event-card__star-shape" d="M12.5 1.75L15.77 8.38L23.08 9.45L17.79 14.6L19.04 21.88L12.5 18.44L5.96 21.88L7.21 14.6L1.92 9.45L9.23 8.38L12.5 1.75Z" />
    </svg>
  </button>
  <div class="event-card__body">
    <div class="event-card__body__header">
      <div class="event-card__body__meta">
        <span data-event-field="dateText">{event.date_text}</span>
        <span data-event-field="institutionName">{event.institution_name}</span>
      </div>
      <div class="event-card__body__title">
        <h2 class="event-card__title" data-event-field="title">{event.title}</h2>
      </div>
    </div>

    <div class="event-card__body__content">
      <p class="event-card__body__description" data-event-card-fade data-event-field="excerpt">{excerpt}</p>
      <div class="event-card__body__actions" data-event-card-fade>
      
        {calendarStartDate ? (
          <GeneralButton
            edge="first"
            verticalPadding="full"
            label={copy.apple}
            icon="calendar"
            data-apple-calendar-button
            data-calendar-title={event.title}
            data-calendar-start={calendarStartDate}
            data-calendar-end={calendarEndDate}
            data-calendar-details={calendarDetails}
            data-calendar-location={calendarLocation}
            data-locale-ui-label="apple"
          />
        ) : null}
        {googleCalendarUrl ? (
          <GeneralButton
            edge={calendarStartDate ? undefined : "first"}
            verticalPadding="full"
            label={copy.google}
            icon="calendar"
            href={googleCalendarUrl}
            data-event-href="googleCalendarUrl"
            data-locale-ui-label="google"
            target="_blank"
            rel="noreferrer"
          />
        ) : null}
        <GeneralButton
          edge={!calendarStartDate && !googleCalendarUrl ? "first" : undefined}
          verticalPadding="full"
          label={copy.directions}
          icon="map"
          href={mapsUrl}
          data-event-href="mapsUrl"
          data-locale-ui-label="directions"
          target="_blank"
          rel="noreferrer"
        />
        <GeneralButton
          edge="last"
          verticalPadding="full"
          label={copy.website}
          icon="exit"
          href={event.source_url}
          data-event-href="sourceUrl"
          data-locale-ui-label="website"
          target="_blank"
          rel="noreferrer"
        />
      </div>
    </div>

  </div>
  {images.length > 0 ? (
    <div class="event-card__media">
      {images.map((imageUrl, index) => (
        <span class="event-card__image-frame">
          <img
            class="event-card__image"
            src={imageUrl}
            alt={index === 0 ? event.title : ""}
            data-event-image-alt={index === 0 ? "" : undefined}
            loading="lazy"
            decoding="async"
            aria-hidden={index === 0 ? undefined : "true"}
          />
        </span>
      ))}
    </div>
  ) : null}
</article>

<script>
  import { initAppleCalendar } from "../scripts/appleCalendar";
  import { initEventCardControls } from "../scripts/eventCardControls";
  import { initEventStars } from "../scripts/eventStars";

  initEventCardControls();
  initEventStars();
  initAppleCalendar();
</script>

<style lang="sass">
  $mobile-breakpoint: 768px
  $desktop-breakpoint: 1440px

  [data-event-card][data-reveal-state='queued']
    opacity: 0
    will-change: opacity

  .event-card
    --event-card-media-row-height: var(--event-card-media-row-height-desktop, 10rem)
    --event-card-media-row-height-active: var(--event-card-media-row-height-active-desktop, 20rem)
    --event-card-media-row-height-current: var(--event-card-media-row-height)
    --event-card-media-gap: 0.5rem
    position: relative
    display: flex
    gap: 1rem
    align-items: flex-start
    justify-content: space-between
    padding: 0.5rem 0 2rem
    border-top: var(--stroke-width) solid var(--stroke)
    cursor: var(--dot-cursor)
    overflow: hidden

    &[data-hide-top-border]
      border-top: 0

    @media (max-width: $mobile-breakpoint)
      flex-direction: column

    &__star
      position: absolute
      z-index: 4
      top: 0
      right: 0
      display: grid
      place-items: center
      padding: 1rem
      border: 0
      appearance: none
      -webkit-tap-highlight-color: transparent
      background: transparent
      color: var(--color-green)
      cursor: var(--dot-cursor)
      pointer-events: auto

      &:focus,
      &:focus-visible
        outline: none

      &[aria-pressed='true'] .event-card__star-shape
        fill: var(--color-pink)
        stroke: var(--color-beige)

      &[data-star-burst] .event-card__star-ring
        animation: event-card-star-ring 0.33s ease-out forwards

      &[data-star-burst] .event-card__star-ring--second
        animation-delay: 0.12s

    &__star-icon
      display: block
      width: 1.5rem
      height: 1.5rem
      overflow: visible

      path
        fill: transparent
        stroke-width: 1
        stroke-linejoin: round
        transform-box: fill-box
        transform-origin: center

    &__star-ring
      opacity: 0
      stroke: var(--color-green)
      pointer-events: none

    &__star-icon &__star-shape
      fill: var(--color-beige)
      stroke: var(--color-green)

    > *
      pointer-events: none

    > .event-card__star
      pointer-events: auto

    &:focus,
    &:focus-visible
      outline: none

    &:not([data-toggle-ready='true'])[data-active='false'] .event-card__body__content
      display: none

    [data-event-card-fade]
      opacity: 0
      pointer-events: none

    &[data-active='true'] [data-event-card-fade]
      pointer-events: auto

    &[data-active='false'] .event-card__body__actions,
    &[data-active='false'] .event-card__body__actions :global(.general-button)
      pointer-events: none

    &[data-active='true'] .event-card__body__actions,
    &[data-active='true'] .event-card__body__actions :global(.general-button)
      pointer-events: auto

    &[data-timing='upcoming']
      content-visibility: auto
      contain-intrinsic-size: auto 14rem

    &__media
      flex: 0 1 auto
      display: grid
      grid-auto-flow: column
      grid-auto-columns: max-content
      align-items: start
      justify-content: start
      gap: var(--event-card-media-gap)
      min-width: 0
      max-height: var(--event-card-media-row-height-current)
      inline-size: fit-content
      max-inline-size: 66%
      overflow-x: auto
      overflow-y: hidden
      overscroll-behavior-x: contain
      pointer-events: auto
      touch-action: pan-y
      -webkit-overflow-scrolling: touch
      scrollbar-width: thin
      padding: 0 var(--page-padding-x)

      &::-webkit-scrollbar
        height: 0.25rem

      &::-webkit-scrollbar-thumb
        background-color: currentColor

      @media screen and (max-width: $desktop-breakpoint)
        max-inline-size: 60%

      @media screen and (max-width: $mobile-breakpoint)
        inline-size: 100%
        max-inline-size: 100%

    &__image-frame
      position: relative
      display: block
      width: max-content
      height: var(--event-card-media-row-height-current)
      overflow: hidden
      pointer-events: auto

    &__image
      display: block
      width: auto
      height: var(--event-card-media-row-height-current)
      pointer-events: auto

    &__body
      flex: 1 1 auto
      display: flex
      flex-direction: column
      min-width: 0
      max-width: 40%
      @media (max-width: $mobile-breakpoint)
        max-width: 100%

      &__header
        display: flex
        flex-direction: column
        gap: 1rem
        user-select: auto
        @media (max-width: $mobile-breakpoint)
          gap: 0.5rem

      &__title
        padding: 0 var(--page-padding-x)
        padding-left: calc(var(--page-padding-x) * 2)

      &__meta
        display: flex
        flex-direction: column
        font-size: var(--type-meta-size)
        text-transform: uppercase
        user-select: auto
        padding: 0 var(--page-padding-x)

      &__content
        display: flex
        flex-direction: column
        gap: 0.5rem
        will-change: height

      &__description
        margin-top: 1rem
        display: -webkit-box
        -webkit-box-orient: vertical
        -webkit-line-clamp: 5
        overflow: hidden
        user-select: auto
        padding: 0 var(--page-padding-x)
        @media (max-width: $mobile-breakpoint)
          -webkit-line-clamp: 3

      &__actions
        display: flex
        flex-wrap: wrap
        column-gap: 0
        row-gap: 0
        pointer-events: none
        overflow: visible
        margin-left: -0.5rem

  :global([data-content-container][data-map-visible]) .event-card
    flex-direction: column

    &__media
      flex-basis: auto
      inline-size: fit-content
      max-inline-size: 100%

    &__body
      max-width: 100%

      &__title
        padding: 0var(--page-padding-x)

      &__description
        -webkit-line-clamp: 3

  :global(.event-card-dot)
    position: absolute
    z-index: -1
    width: var(--dot-card)
    height: var(--dot-card)
    background: var(--color-pink)
    mask: var(--dot-mask) center / contain no-repeat
    -webkit-mask: var(--dot-mask) center / contain no-repeat
    transform: translate(-50%, var(--event-card-dot-translate-y, -50%)) rotate(var(--dot-rotation)) scaleX(var(--dot-scale-x)) scaleY(var(--dot-scale-y))
    transform-origin: center
    pointer-events: none

  @keyframes event-card-star-ring
    0%
      opacity: 1
      transform: scale(0.72)
    100%
      opacity: 0
      transform: scale(2)

  @media (max-width: $mobile-breakpoint)
    .event-card
      --event-card-media-row-height: var(--event-card-media-row-height-mobile, 7.5rem)
      --event-card-media-row-height-active: var(--event-card-media-row-height-active-mobile, 10rem)

      flex-direction: column

      &[data-timing='upcoming']
        contain-intrinsic-size: auto 16rem

      &__media
        flex-basis: auto
        inline-size: 100%
        max-inline-size: 100%
</style>
