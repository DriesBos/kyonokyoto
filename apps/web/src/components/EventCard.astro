---
import GeneralButton from "./GeneralButton.astro";

type EventRow = {
  id: string;
  title: string;
  artist_name: string | null;
  categories: string[];
  date_text: string;
  institution_name: string;
  venue_name: string | null;
  address_text: string | null;
  directions_query: string | null;
  calendar_starts_at: string | null;
  calendar_ends_at: string | null;
  primary_image_url: string | null;
  image_urls: string[] | null;
  source_url: string;
  description: string | null;
};

type Props = {
  event: EventRow;
  mapsUrl: string;
  calendarUrl: string | null;
  excerpt: string;
};

const { event, mapsUrl, calendarUrl, excerpt } = Astro.props;

const normalizeCategory = (value: string) =>
  value
    .toLowerCase()
    .trim()
    .replace(/&/g, "and")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "");

const categorySlugs = event.categories.map(normalizeCategory);
const imageUrls = (event.image_urls ?? []).filter(Boolean);
const images = imageUrls.length > 0 ? imageUrls : event.primary_image_url ? [event.primary_image_url] : [];
---

<article
  class="event-card"
  data-event-card
  data-event-card-toggle
  data-active="false"
  data-categories={categorySlugs.join("|")}
  role="button"
  tabindex="0"
  aria-pressed="false"
>

  <div class="event-card__body">
    <div class="event-card__body__header">
      <h2 class="event-card__title">{event.title}</h2>
      {event.artist_name ? <h3 class="event-card__artist">{event.artist_name}</h3> : null}
    </div>
    <div class="event-card__body__content">
      <p class="event-card__description">{excerpt}</p>
      <div class="event-card__meta">
        <span>{event.institution_name}</span>
        <span>{event.date_text}</span>
      </div>
          <div class="event-card__actions">
      <GeneralButton label="Source" href={event.source_url} target="_blank" rel="noreferrer" />
      <GeneralButton label="Directions" href={mapsUrl} target="_blank" rel="noreferrer" />
      {
        calendarUrl ? (
          <GeneralButton label="Add to Calendar" href={calendarUrl} target="_blank" rel="noreferrer" />
        ) : (
          <GeneralButton label="Calendar soon" disabled={true} />
        )
      }
    </div>
    </div>

    <!-- {
      event.categories.length > 0 ? (
        <ul class="event-card__categories" aria-label="Categories">
          {event.categories.map((category) => (
            <li>{category}</li>
          ))}
        </ul>
      ) : null
    } -->

    <!-- <dl class="event-card__facts">
      <div>
        <dt>Venue</dt>
        <dd>{event.venue_name ?? event.institution_name}</dd>
      </div>
    </dl> -->



  </div>
    <div class="event-card__media">
    {images.length > 0 ? (
      images.map((imageUrl, index) => (
        <img
          class="event-card__image"
          src={imageUrl}
          alt={index === 0 ? event.title : ""}
          loading="lazy"
          aria-hidden={index === 0 ? undefined : "true"}
        />
      ))
    ) : (
      <div class="event-card__image event-card__image--placeholder">KyōNoKyōto</div>
    )}
  </div>
</article>

<script>
  if (!window.__eventCardToggleBound) {
    const interactiveSelector = "a, button, input, select, textarea, summary, [role='button']";

    const toggleCard = (card) => {
      const isActive = card.getAttribute("data-active") === "true";
      const next = !isActive;

      card.setAttribute("data-active", String(next));
      card.setAttribute("aria-pressed", String(next));
    };

    document.addEventListener("click", (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;

      const card = target.closest("[data-event-card-toggle]");
      if (!(card instanceof HTMLElement)) return;
      if (target.closest(interactiveSelector) && target !== card) return;

      toggleCard(card);
    });

    document.addEventListener("keydown", (event) => {
      const target = event.target;
      if (!(target instanceof HTMLElement)) return;
      if (!target.matches("[data-event-card-toggle]")) return;
      if (event.key !== "Enter" && event.key !== " ") return;

      event.preventDefault();
      toggleCard(target);
    });

    window.__eventCardToggleBound = true;
  }
</script>
