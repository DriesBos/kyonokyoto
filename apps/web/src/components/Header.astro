---
import Logo from './Logo.astro';
import GeneralButton from './GeneralButton.astro';
import { cityConfigs, cityConfigFor, type AppCity } from '../lib/cities';
import type { AppLocale } from '../lib/i18n';
import { uiText } from '../lib/i18n';
import { routePathFor } from '../lib/routeState';
import type { CategoryOption } from '../lib/sources';
import { CATEGORY_DIMENSIONS } from '../../../../data/categories.mjs';

type Props = {
  categories?: CategoryOption[];
  activeTiming?: 'ongoing' | 'upcoming' | 'permanent' | '';
  showFilters?: boolean;
  showTimingFilters?: boolean;
  compact?: boolean;
  city?: AppCity;
  locale?: AppLocale;
  showLanguageOption?: boolean;
};

const {
  categories = [],
  activeTiming = '',
  showFilters = true,
  showTimingFilters = true,
  compact = false,
  city = 'kyoto',
  locale = 'en',
  showLanguageOption = false,
} = Astro.props;
const copy = uiText.en;
const homeHref = routePathFor({ city, locale });
const localePathFor = (targetLocale: AppLocale) => routePathFor({ city, locale: targetLocale });
const nextLocale: AppLocale = locale === 'en' ? 'ja' : 'en';
const currentCity = cityConfigFor(city);
const currentCityLabel = currentCity?.label ?? city;
const brandLabel = currentCity?.brandLabel ?? 'Kyō-no-Kyōto';
const languageLabels: Record<AppLocale, string> = {
  en: 'eng',
  ja: 'jp',
};
const timingFilters = showTimingFilters
  ? [
      { slug: 'ongoing', label: copy.ongoing },
      { slug: 'upcoming', label: copy.upcoming },
    ]
  : [];
const categoryGroups = CATEGORY_DIMENSIONS.map((dimension) => ({
  dimension,
  categories: categories.filter((category) => category.dimension === dimension),
}));
const showFilterControls = showFilters && (categories.length > 0 || timingFilters.length > 0);
---

<header class="headerWrapper" data-category-filter data-active-timing={activeTiming}>
  <div
    class:list={['mainHeader', compact && 'mainHeader--compact']}
    data-main-header
    data-stuck={compact ? '' : undefined}
  >
    <a class="mainHeader__logo" href={homeHref} aria-label={`${brandLabel} home`}>
      <Logo label={brandLabel} />
    </a>

    <div
      class="category-filter"
      aria-label={showFilterControls ? copy.filtersAria : copy.controlsAria}
      role="group"
    >
      <div class="category-filter__toolbar">
        {
          showFilterControls ? (
            <GeneralButton
              class="mainHeader__filter-toggle"
              edge="first"
              verticalPadding="full"
              label={copy.filter}
              pressed={false}
              showDot={true}
              data-filter-disclosure
              aria-expanded="false"
              aria-controls="category-filter-options"
            />
          ) : null
        }
        <GeneralButton
          edge={showFilterControls ? undefined : 'first'}
          verticalPadding="full"
          label={copy.map}
          pressed={false}
          showDot={true}
          data-map-toggle
          aria-expanded="false"
          aria-controls="map-section"
        />
        <GeneralButton
          edge={showLanguageOption ? undefined : 'last'}
          verticalPadding="full"
          label={currentCityLabel}
          pressed={false}
          showDot={true}
          aria-label={`Choose city. Current city: ${currentCityLabel}`}
          data-city-disclosure
          aria-expanded="false"
          aria-controls="city-filter-options"
        />
        {
          showLanguageOption ? (
            <GeneralButton
              edge="last"
              verticalPadding="full"
              href={localePathFor(nextLocale)}
              label={languageLabels[nextLocale]}
              aria-label={`${copy.languageAria}: ${languageLabels[nextLocale]}`}
              hreflang={nextLocale}
            />
          ) : null
        }
      </div>
      {
        showFilterControls ? (
          <div
            class="category-filter__options"
            id="category-filter-options"
            data-filter-options
            aria-hidden="true"
            inert
          >
            {categoryGroups.map((group) => (
              <div
                class="category-filter__group"
                role="group"
                aria-label={group.dimension.replace('_category', '')}
              >
                {group.categories.map((category) => (
                  <GeneralButton
                    label={'#' + category.label}
                    pressed={false}
                    verticalPadding="full"
                    showDot={true}
                    dataCategory={category.slug}
                    dataCategoryDimension={category.dimension}
                    dataCategoryButton={true}
                    dataFilterButton={true}
                  />
                ))}
              </div>
            ))}
            {timingFilters.map((filter) => (
              <GeneralButton
                label={filter.label}
                pressed={activeTiming === filter.slug}
                verticalPadding="full"
                showDot={true}
                dataTiming={filter.slug}
                dataTimingButton={true}
                dataFilterButton={true}
              />
            ))}
            <GeneralButton
              label={copy.starred}
              icon="star"
              pressed={false}
              verticalPadding="full"
              showDot={true}
              dataStarredButton={true}
              dataFilterButton={true}
              hidden
            />
          </div>
        ) : null
      }
      <div
        class="category-filter__options"
        id="city-filter-options"
        data-city-options
        aria-label="Cities"
        role="group"
        aria-hidden="true"
        inert
      >
        {cityConfigs.map((targetCity) => (
          <GeneralButton
            href={routePathFor({ city: targetCity.slug, locale })}
            label={targetCity.label}
            verticalPadding="full"
            showDot={true}
            data-city-toggle
            data-city-button
            data-city-option={targetCity.slug}
            aria-current={targetCity.slug === city ? 'page' : undefined}
          />
        ))}
      </div>
    </div>
  </div>
</header>

<script>
  import { initHeaderControls } from '../scripts/headerControls';

  initHeaderControls();
</script>

<style lang="sass">
  $mobile-breakpoint: 768px

  .headerWrapper
    display: contents

  .mainHeader
    position: sticky
    top: 0
    z-index: 100
    isolation: isolate
    display: flex
    justify-content: space-between
    align-items: flex-start
    gap: 0
    padding: 0.5rem 0
    padding-top: max(0.5rem, env(safe-area-inset-top))
    background-color: var(--color-beige)
    overflow: visible

    &::after
      content: ""
      position: absolute
      z-index: 2
      inset-inline: 0
      bottom: 0
      border-top: var(--stroke-width) solid var(--stroke)
      opacity: 0
      pointer-events: none

      transition: opacity 165ms ease

    &[data-stuck]
      :global(.mainHeader__logo svg),
      :global(.mainHeader__logo .logo-wordmark)
        height: calc(var(--type-title-size) * 1.22)
        font-size: var(--type-title-size)

      &::after
        opacity: 1

    &__logo
      position: relative
      z-index: 1
      flex: 0 0 auto
      display: block
      padding-left: var(--page-padding-x)

    &__logo :global(svg),
    &__logo :global(.logo-wordmark)
      width: auto
      height: calc(var(--type-logo-size) * 1.22)
      font-size: var(--type-logo-size)
      line-height: 1.22
      display: block
      transition: height 165ms ease

  .mainHeader--compact
    &::after
      opacity: 1

    :global(.mainHeader__logo svg),
    :global(.mainHeader__logo .logo-wordmark)
      height: calc(var(--type-title-size) * 1.22)
      font-size: var(--type-title-size)

  .category-filter
    position: relative
    z-index: 1
    display: flex
    flex-direction: column
    align-items: flex-end
    margin-left: auto
    min-width: 0
    overflow: visible

    &__toolbar
      display: inline-flex
      align-items: flex-start
      justify-content: flex-end
      flex-wrap: wrap
      column-gap: 0
      row-gap: var(--control-gap)

    &__options
      display: flex
      flex-wrap: wrap
      justify-content: flex-end
      column-gap: 0
      width: min(100%, 48rem)
      padding-right: 0.5rem
      height: 0
      overflow: hidden
      pointer-events: none

      &[data-mobile-open]
        overflow: visible
        pointer-events: auto

    &__group
      display: contents

  @media (max-width: $mobile-breakpoint)
    .mainHeader
      gap: 0
      flex-direction: row
      align-items: flex-start

      &__logo :global(svg),
      &__logo :global(.logo-wordmark)
        height: calc(var(--type-logo-size) * 0.96)
        font-size: calc(var(--type-logo-size) * 0.79)

    :global(.mainHeader__filter-toggle)
      display: inline-flex
      align-items: center
      justify-content: flex-start

    .category-filter
      flex: 1 1 auto
      flex-direction: column
      align-items: flex-end

      &__toolbar,
      &__options
        width: 100%

      &__options
        height: 0
        pointer-events: none

        :global([data-filter-button]),
        :global([data-city-button])
          opacity: 0
          pointer-events: none

      &__options[data-mobile-open]
        pointer-events: auto

        :global([data-filter-button]),
        :global([data-city-button])
          pointer-events: auto

  :global([data-city-option][aria-current='page'] .general-button__dot)
    opacity: 1
</style>
