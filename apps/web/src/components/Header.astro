---
import Logo from "./Logo.astro";
import GeneralButton from "./GeneralButton.astro";

type CategoryOption = {
  slug: string;
  label: string;
};

type Props = {
  categories: CategoryOption[];
};

const { categories } = Astro.props;
const timingFilters = [
  { slug: "ongoing", label: "ongoing" },
  { slug: "upcoming", label: "upcoming" },
];
---

<header class="site-header" data-category-filter>
  <a class="site-header__logo" href="/" aria-label="KyōNoKyōto home">
    <Logo />
  </a>

  {
    categories.length > 0 || timingFilters.length > 0 ? (
      <div class="category-filter" aria-label="Filter events by category" role="group">
        <div class="category-filter__toolbar">
          <GeneralButton
            class="site-header__filter-toggle"
            label="filter"
            pressed={false}
            showDot={true}
            data-filter-disclosure
            aria-expanded="false"
            aria-controls="category-filter-options"
          />
          <GeneralButton
            label="ambient"
            icon="sound"
            pressed={false}
            showDot={true}
            dataAmbientSoundButton={true}
          />
          <GeneralButton
            label="theme"
            pressed={false}
            showDot={true}
            data-theme-toggle
          />
        </div>
        <div class="category-filter__options" id="category-filter-options" data-filter-options>
          {timingFilters.map((filter) => (
            <GeneralButton
              label={filter.label}
              pressed={false}
              showDot={true}
              dataTiming={filter.slug}
              dataTimingButton={true}
              dataFilterButton={true}
            />
          ))}
          {categories.map((category) => (
            <GeneralButton
              label={category.label}
              pressed={false}
              showDot={true}
              dataCategory={category.slug}
              dataCategoryButton={true}
              dataFilterButton={true}
            />
          ))}
        </div>
      </div>
    ) : null
  }
</header>

<script>
  import { fadeIn, fadeOut, killFadeTransitionTweens, setFadeHidden, setFadeVisible } from "../lib/fadeTransition";
  import { createHeightTransitionTimeline, killHeightTransitionTweens, toHeight } from "../lib/heightTransition";

  const normalizeCategory = (value) =>
    value
      .toLowerCase()
      .trim()
      .replace(/&/g, "and")
      .replace(/[^a-z0-9]+/g, "-")
      .replace(/^-+|-+$/g, "");

  const root = document.querySelector("[data-category-filter]");

  if (root) {
    const categoryButtons = Array.from(root.querySelectorAll("[data-category-button]"));
    const timingButtons = Array.from(root.querySelectorAll("[data-timing-button]"));
    const buttons = [...timingButtons, ...categoryButtons];
    const disclosure = root.querySelector("[data-filter-disclosure]");
    const themeToggleButtons = Array.from(root.querySelectorAll("[data-theme-toggle]"));
    const filterPanel = root.querySelector("[data-filter-options]");
    const cards = Array.from(document.querySelectorAll("[data-event-card]"));
    const groups = Array.from(document.querySelectorAll("[data-event-group]"));
    const divider = document.querySelector("[data-event-divider]");
    const filteredEmptyState = document.querySelector("[data-filter-empty]");
    const countLabel = document.querySelector("[data-event-count]");
    const themeRoot = document.documentElement;

    const total = cards.length;
    let activeCategory = "";
    let activeTiming = "";
    let filterExpandedScrollOrigin = null;
    const filterButtons = buttons.filter((button): button is HTMLElement => button instanceof HTMLElement);

    const isFilterExpanded = () =>
      disclosure instanceof HTMLElement && disclosure.getAttribute("aria-expanded") === "true";

    const isMudTheme = () => themeRoot.getAttribute("data-theme") === "mud";

    const syncThemeButtons = () => {
      const isActive = isMudTheme();

      themeToggleButtons.forEach((button) => {
        if (!(button instanceof HTMLElement)) return;
        button.setAttribute("aria-pressed", String(isActive));
        button.dataset.themeState = isActive ? "mud" : "default";
      });
    };

    const setTheme = (nextTheme) => {
      if (nextTheme === "mud") {
        themeRoot.setAttribute("data-theme", "mud");
      } else {
        themeRoot.removeAttribute("data-theme");
      }

      syncThemeButtons();
    };

    const setFilterDisclosureExpanded = (nextExpanded) => {
      if (!(disclosure instanceof HTMLElement)) return;

      disclosure.setAttribute("aria-expanded", String(nextExpanded));
      disclosure.setAttribute("aria-pressed", String(nextExpanded));
      filterExpandedScrollOrigin = nextExpanded ? window.scrollY : null;
      animateFilterDisclosure(nextExpanded);
    };

    const closeFilterDisclosure = () => {
      if (!isFilterExpanded()) return;

      setFilterDisclosureExpanded(false);
    };

    const setFilterPanelInteractivity = (isInteractive) => {
      if (!(filterPanel instanceof HTMLElement)) return;

      filterPanel.toggleAttribute("inert", !isInteractive);
      filterPanel.setAttribute("aria-hidden", String(!isInteractive));
      buttons.forEach((button) => {
        if (!(button instanceof HTMLElement)) return;

        if (isInteractive) {
          button.removeAttribute("tabindex");
        } else {
          button.setAttribute("tabindex", "-1");
        }
      });
    };

    const animateFilterDisclosure = (nextExpanded) => {
      if (!(filterPanel instanceof HTMLElement)) {
        filterPanel?.toggleAttribute("data-mobile-open", nextExpanded);
        return;
      }

      const startHeight = filterPanel.offsetHeight;

      killHeightTransitionTweens(filterPanel);
      killFadeTransitionTweens(filterButtons);
      filterPanel.style.height = `${startHeight}px`;
      filterPanel.style.overflow = "hidden";
      filterPanel.toggleAttribute("data-mobile-open", nextExpanded);
      setFilterPanelInteractivity(nextExpanded);
      if (nextExpanded) {
        setFadeHidden(filterButtons);
      } else {
        fadeOut(filterButtons);
      }

      const targetHeight = nextExpanded ? filterPanel.scrollHeight : 0;

      const timeline = createHeightTransitionTimeline({
        onComplete: () => {
          filterPanel.style.height = nextExpanded ? "auto" : "0px";
          filterPanel.style.overflow = nextExpanded ? "" : "hidden";
        },
      });

      toHeight(timeline, filterPanel, targetHeight, nextExpanded, 0);
      if (nextExpanded) {
        fadeIn(filterButtons, { delay: 0.06 });
      }
    };

    const syncFilterPanelState = () => {
      if (!(filterPanel instanceof HTMLElement) || !(disclosure instanceof HTMLElement)) return;

      killHeightTransitionTweens(filterPanel);

      const isExpanded = disclosure.getAttribute("aria-expanded") === "true";
      filterPanel.toggleAttribute("data-mobile-open", isExpanded);
      filterPanel.style.height = isExpanded ? "auto" : "0px";
      filterPanel.style.overflow = isExpanded ? "" : "hidden";
      if (isExpanded) {
        setFadeVisible(filterButtons);
      } else {
        setFadeHidden(filterButtons);
      }
      setFilterPanelInteractivity(isExpanded);
    };

    const updateCount = (visibleCount, activeLabel) => {
      if (!countLabel) return;

      const noun = visibleCount === 1 ? "event" : "events";
      countLabel.textContent = activeLabel
        ? `${visibleCount} published ${noun} in ${activeLabel}`
        : `${visibleCount} published ${noun} in the feed`;
    };

    const applyFilter = () => {
      let visibleCount = 0;

      cards.forEach((card) => {
        const categories = (card.getAttribute("data-categories") || "")
          .split("|")
          .filter(Boolean)
          .map(normalizeCategory);
        const timing =
          card.getAttribute("data-timing") ||
          card.closest("[data-event-group]")?.getAttribute("data-event-group-name") ||
          "";
        const matchesCategory = !activeCategory || categories.includes(activeCategory);
        const matchesTiming = !activeTiming || timing === activeTiming;
        const matches = matchesCategory && matchesTiming;

        card.toggleAttribute("hidden", !matches);

        if (matches) visibleCount += 1;
      });

      let visibleGroups = 0;

      groups.forEach((group) => {
        const visibleCards = group.querySelectorAll("[data-event-card]:not([hidden])").length;
        group.toggleAttribute("hidden", visibleCards === 0);

        if (visibleCards > 0) visibleGroups += 1;
      });

      if (divider) {
        divider.toggleAttribute("hidden", visibleGroups < 2);
      }

      const activeLabels = [
        timingButtons.find((button) => button.dataset.timing === activeTiming),
        categoryButtons.find((button) => button.dataset.category === activeCategory),
      ]
        .filter(Boolean)
        .map((button) => button.querySelector(".general-button__label")?.textContent || "")
        .filter(Boolean);
      const activeLabel = activeLabels.join(" + ");

      if (filteredEmptyState) {
        filteredEmptyState.toggleAttribute("hidden", visibleCount > 0 || (!activeCategory && !activeTiming));
      }

      updateCount(visibleCount || (activeCategory || activeTiming ? 0 : total), activeLabel);
      document.dispatchEvent(new CustomEvent("event-filter:updated"));
    };

    categoryButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const nextCategory = button.dataset.category || "";
        activeCategory = activeCategory === nextCategory ? "" : nextCategory;

        categoryButtons.forEach((item) => {
          const isActive = item.dataset.category === activeCategory;
          item.setAttribute("aria-pressed", String(isActive));
        });

        applyFilter();
      });
    });

    timingButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const nextTiming = button.dataset.timing || "";
        activeTiming = activeTiming === nextTiming ? "" : nextTiming;

        timingButtons.forEach((item) => {
          const isActive = item.dataset.timing === activeTiming;
          item.setAttribute("aria-pressed", String(isActive));
        });

        applyFilter();
      });
    });

    if (disclosure && filterPanel) {
      syncFilterPanelState();
      filterExpandedScrollOrigin = isFilterExpanded() ? window.scrollY : null;

      disclosure.addEventListener("click", () => {
        setFilterDisclosureExpanded(!isFilterExpanded());
      });
    }

    themeToggleButtons.forEach((button) => {
      if (!(button instanceof HTMLElement)) return;

      button.addEventListener("click", () => {
        setTheme(isMudTheme() ? "default" : "mud");
      });
    });

    updateCount(total, "");
    syncThemeButtons();

    const stickyOffset = () => {
      const pagePaddingY = Number.parseFloat(
        getComputedStyle(document.documentElement).getPropertyValue("--page-padding-y")
      );
      return Number.isFinite(pagePaddingY) ? pagePaddingY : 0;
    };

    const syncStickyState = () => {
      if (!(root instanceof HTMLElement)) return;
      const isStuck = root.getBoundingClientRect().top <= stickyOffset() + 0.5;
      root.toggleAttribute("data-stuck", isStuck);
    };

    const maybeCloseFilterOnScroll = () => {
      if (filterExpandedScrollOrigin === null) return;

      const scrollDelta = Math.abs(window.scrollY - filterExpandedScrollOrigin);
      if (scrollDelta > window.innerHeight * 0.5) {
        closeFilterDisclosure();
      }
    };

    syncStickyState();
    document.addEventListener("click", (event) => {
      if (!isFilterExpanded()) return;
      if (!(event.target instanceof Node)) return;
      if (root.contains(event.target)) return;

      closeFilterDisclosure();
    });
    document.addEventListener("keydown", (event) => {
      if (event.key !== "Escape") return;

      closeFilterDisclosure();
    });
    window.addEventListener("scroll", syncStickyState, { passive: true });
    window.addEventListener("scroll", maybeCloseFilterOnScroll, { passive: true });
    window.addEventListener("resize", syncStickyState);
  }
</script>
