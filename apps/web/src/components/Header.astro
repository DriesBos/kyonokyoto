---
import Logo from "./Logo.astro";
import GeneralButton from "./GeneralButton.astro";
import PageEdgeStrokes from "./PageEdgeStrokes.astro";
import type { AppLocale } from "../lib/i18n";
import { LOCALE_COOKIE, LOCALE_STORAGE_KEY, uiText } from "../lib/i18n";

type CategoryOption = {
  slug: string;
  label: string;
};

type Props = {
  categories?: CategoryOption[];
  activeCategory?: string;
  activeTiming?: "ongoing" | "upcoming" | "";
  showFilters?: boolean;
  showTimingFilters?: boolean;
  compact?: boolean;
  locale?: AppLocale;
};

const {
  categories = [],
  activeCategory = "",
  activeTiming = "",
  showFilters = true,
  showTimingFilters = true,
  compact = false,
  locale = "en",
} = Astro.props;
const copy = uiText.en;
const homeHref = `/${locale}/`;
const localePathFor = (targetLocale: AppLocale) => `/${targetLocale}/`;
const nextLocale: AppLocale = locale === "en" ? "ja" : "en";
const languageLabels: Record<AppLocale, string> = {
  en: "eng",
  ja: "jp",
};
const timingFilters = showTimingFilters
  ? [
      { slug: "ongoing", label: copy.ongoing },
      { slug: "upcoming", label: copy.upcoming },
    ]
  : [];
const showFilterControls = showFilters && (categories.length > 0 || timingFilters.length > 0);
---

<header class="headerWrapper" data-category-filter data-active-category={activeCategory} data-active-timing={activeTiming}>
  <PageEdgeStrokes position="top" lines={6} />
  <div class:list={["mainHeader", compact && "mainHeader--compact"]} data-main-header data-stuck={compact ? "" : undefined}>
    <a class="mainHeader__logo" href={homeHref} aria-label={copy.homeAria}>
      <Logo />
    </a>

    <div class="category-filter" aria-label={showFilterControls ? copy.filtersAria : copy.controlsAria} role="group">
      <div class="category-filter__toolbar">
        {
          showFilterControls ? (
            <GeneralButton
              class="mainHeader__filter-toggle"
              label={copy.filter}
              pressed={false}
              showDot={true}
              data-filter-disclosure
              aria-expanded="false"
              aria-controls="category-filter-options"
            />
          ) : null
        }
        <GeneralButton
          label={copy.map}
          pressed={false}
          showDot={true}
          data-map-toggle
          aria-expanded="false"
          aria-controls="map-section"
        />
        <GeneralButton
          label={languageLabels[locale]}
          aria-label={`${copy.languageAria}: ${languageLabels[locale]}`}
          data-locale-toggle
          data-locale-cookie={LOCALE_COOKIE}
          data-locale-storage={LOCALE_STORAGE_KEY}
          data-locale-option={nextLocale}
          data-locale-href={localePathFor(nextLocale)}
        />
      </div>
      {
        showFilterControls ? (
          <div
            class="category-filter__options"
            id="category-filter-options"
            data-filter-options
            aria-hidden="true"
            inert
          >
            {categories.map((category) => (
              <GeneralButton
                label={"#" + category.label}
                pressed={activeCategory === category.slug}
                showDot={true}
                dataCategory={category.slug}
                dataCategoryButton={true}
                dataFilterButton={true}
              />
            ))}
            {timingFilters.map((filter) => (
              <GeneralButton
                label={filter.label}
                pressed={activeTiming === filter.slug}
                showDot={true}
                dataTiming={filter.slug}
                dataTimingButton={true}
                dataFilterButton={true}
              />
            ))}
          </div>
        ) : null
      }
    </div>
  </div>
</header>

<script>
  import { fadeIn, fadeOut, killFadeTransitionTweens, setFadeHidden, setFadeVisible } from "../lib/fadeTransition";
  import { createHeightTransitionTimeline, killHeightTransitionTweens, toHeight } from "../lib/heightTransition";

  const normalizeCategory = (value) =>
    value
      .toLowerCase()
      .trim()
      .replace(/&/g, "and")
      .replace(/[^a-z0-9]+/g, "-")
      .replace(/^-+|-+$/g, "");

  const root = document.querySelector("[data-category-filter]");

  if (root) {
    const headerCategoryButtons = Array.from(root.querySelectorAll("[data-category-button]"));
    const categoryButtons = Array.from(document.querySelectorAll("[data-category-button]"));
    const timingButtons = Array.from(root.querySelectorAll("[data-timing-button]"));
    const buttons = [...timingButtons, ...headerCategoryButtons];
    const disclosure = root.querySelector("[data-filter-disclosure]");
    const filterPanel = root.querySelector("[data-filter-options]");
    const cards = Array.from(document.querySelectorAll("[data-event-card]"));
    const groups = Array.from(document.querySelectorAll("[data-event-group]"));
    const divider = document.querySelector("[data-event-divider]");
    const filteredEmptyState = document.querySelector("[data-filter-empty]");
    const countLabel = document.querySelector("[data-event-count]");
    const mapToggle = root.querySelector("[data-map-toggle]");
    const contentContainer = document.querySelector("[data-content-container]");
    const mapSection = document.querySelector("[data-map-section]");
    const eventsSection = document.querySelector("[data-events-section]");
    const mainHeader = root.querySelector("[data-main-header]");

    const total = cards.length;
    let activeCategory = root instanceof HTMLElement ? root.dataset.activeCategory || "" : "";
    let activeTiming = root instanceof HTMLElement ? root.dataset.activeTiming || "" : "";
    let filterExpandedScrollOrigin = null;
    const filterButtons = buttons.filter((button): button is HTMLElement => button instanceof HTMLElement);
    const getScrollRoot = () => (eventsSection instanceof HTMLElement ? eventsSection : window);
    const getScrollTop = () => {
      const scrollRoot = getScrollRoot();
      return scrollRoot instanceof HTMLElement ? scrollRoot.scrollTop : window.scrollY;
    };
    const getScrollHeight = () => {
      const scrollRoot = getScrollRoot();
      return scrollRoot instanceof HTMLElement ? scrollRoot.clientHeight : window.innerHeight;
    };

    const isFilterExpanded = () =>
      disclosure instanceof HTMLElement && disclosure.getAttribute("aria-expanded") === "true";
    const isFilteringActive = () => Boolean(activeCategory || activeTiming);

    const syncFilterDisclosureButtonState = () => {
      if (!(disclosure instanceof HTMLElement)) return;

      const isExpanded = isFilterExpanded();
      const filteringActive = isFilteringActive();
      disclosure.setAttribute("aria-pressed", String(isExpanded || filteringActive));
      disclosure.dataset.filteringActive = String(filteringActive);
    };

    const setFilterDisclosureExpanded = (nextExpanded) => {
      if (!(disclosure instanceof HTMLElement)) return;

      disclosure.setAttribute("aria-expanded", String(nextExpanded));
      syncFilterDisclosureButtonState();
      filterExpandedScrollOrigin = nextExpanded ? getScrollTop() : null;
      animateFilterDisclosure(nextExpanded);
    };

    const closeFilterDisclosure = () => {
      if (!isFilterExpanded()) return;

      setFilterDisclosureExpanded(false);
    };

    const setFilterPanelInteractivity = (isInteractive) => {
      if (!(filterPanel instanceof HTMLElement)) return;

      filterPanel.toggleAttribute("inert", !isInteractive);
      filterPanel.setAttribute("aria-hidden", String(!isInteractive));
      buttons.forEach((button) => {
        if (!(button instanceof HTMLElement)) return;

        if (isInteractive) {
          button.removeAttribute("tabindex");
        } else {
          button.setAttribute("tabindex", "-1");
        }
      });
    };

    const animateFilterDisclosure = (nextExpanded) => {
      if (!(filterPanel instanceof HTMLElement)) {
        filterPanel?.toggleAttribute("data-mobile-open", nextExpanded);
        return;
      }

      const startHeight = filterPanel.offsetHeight;

      killHeightTransitionTweens(filterPanel);
      killFadeTransitionTweens(filterButtons);
      filterPanel.style.height = `${startHeight}px`;
      filterPanel.style.overflow = "hidden";
      filterPanel.toggleAttribute("data-mobile-open", nextExpanded);
      setFilterPanelInteractivity(nextExpanded);
      if (nextExpanded) {
        setFadeHidden(filterButtons);
      } else {
        fadeOut(filterButtons);
      }

      const targetHeight = nextExpanded ? filterPanel.scrollHeight : 0;

      const timeline = createHeightTransitionTimeline({
        onComplete: () => {
          filterPanel.style.height = nextExpanded ? "auto" : "0px";
          filterPanel.style.overflow = nextExpanded ? "" : "hidden";
        },
      });

      toHeight(timeline, filterPanel, targetHeight, nextExpanded, 0);
      if (nextExpanded) {
        fadeIn(filterButtons, { delay: 0.06 });
      }
    };

    const syncFilterPanelState = () => {
      if (!(filterPanel instanceof HTMLElement) || !(disclosure instanceof HTMLElement)) return;

      killHeightTransitionTweens(filterPanel);

      const isExpanded = disclosure.getAttribute("aria-expanded") === "true";
      filterPanel.toggleAttribute("data-mobile-open", isExpanded);
      filterPanel.style.height = isExpanded ? "auto" : "0px";
      filterPanel.style.overflow = isExpanded ? "" : "hidden";
      if (isExpanded) {
        setFadeVisible(filterButtons);
      } else {
        setFadeHidden(filterButtons);
      }
      setFilterPanelInteractivity(isExpanded);
    };

    const updateCount = (visibleCount, activeLabel) => {
      if (!countLabel) return;

      const noun = visibleCount === 1 ? "event" : "events";
      countLabel.textContent = activeLabel
        ? `${visibleCount} published ${noun} in ${activeLabel}`
        : `${visibleCount} published ${noun} in the feed`;
    };

    const applyFilter = () => {
      let visibleCount = 0;

      cards.forEach((card) => {
        const categories = (card.getAttribute("data-categories") || "")
          .split("|")
          .filter(Boolean)
          .map(normalizeCategory);
        const timing =
          card.getAttribute("data-timing") ||
          card.closest("[data-event-group]")?.getAttribute("data-event-group-name") ||
          "";
        const matchesCategory = !activeCategory || categories.includes(activeCategory);
        const matchesTiming = !activeTiming || timing === activeTiming;
        const matches = matchesCategory && matchesTiming;

        card.toggleAttribute("hidden", !matches);

        if (matches) visibleCount += 1;
      });

      let visibleGroups = 0;

      groups.forEach((group) => {
        const visibleCards = group.querySelectorAll("[data-event-card]:not([hidden])").length;
        group.toggleAttribute("hidden", visibleCards === 0);

        if (visibleCards > 0) visibleGroups += 1;
      });

      if (divider) {
        divider.toggleAttribute("hidden", visibleGroups < 2);
      }

      const activeLabels = [
        timingButtons.find((button) => button.dataset.timing === activeTiming),
        categoryButtons.find((button) => button.dataset.category === activeCategory),
      ]
        .filter(Boolean)
        .map((button) => button.querySelector(".general-button__label")?.textContent || "")
        .filter(Boolean);
      const activeLabel = activeLabels.join(" + ");

      if (filteredEmptyState) {
        filteredEmptyState.toggleAttribute("hidden", visibleCount > 0 || (!activeCategory && !activeTiming));
      }

      updateCount(visibleCount || (activeCategory || activeTiming ? 0 : total), activeLabel);
      syncFilterDisclosureButtonState();
      document.dispatchEvent(new CustomEvent("event-filter:updated"));
    };

    categoryButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const nextCategory = button.dataset.category || "";
        activeCategory = activeCategory === nextCategory ? "" : nextCategory;

        categoryButtons.forEach((item) => {
          const isActive = item.dataset.category === activeCategory;
          item.setAttribute("aria-pressed", String(isActive));
        });

        applyFilter();
      });
    });

    timingButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const nextTiming = button.dataset.timing || "";
        activeTiming = activeTiming === nextTiming ? "" : nextTiming;

        timingButtons.forEach((item) => {
          const isActive = item.dataset.timing === activeTiming;
          item.setAttribute("aria-pressed", String(isActive));
        });

        applyFilter();
      });
    });

    if (disclosure && filterPanel) {
      syncFilterPanelState();
      filterExpandedScrollOrigin = isFilterExpanded() ? getScrollTop() : null;

      disclosure.addEventListener("click", () => {
        setFilterDisclosureExpanded(!isFilterExpanded());
      });
    }

    const initialActiveLabels = [
      timingButtons.find((button) => button.dataset.timing === activeTiming),
      categoryButtons.find((button) => button.dataset.category === activeCategory),
    ]
      .filter(Boolean)
      .map((button) => button.querySelector(".general-button__label")?.textContent || "")
      .filter(Boolean);

    updateCount(total, initialActiveLabels.join(" + "));
    syncFilterDisclosureButtonState();

    const setMapVisible = (nextVisible) => {
      if (!(contentContainer instanceof HTMLElement) || !(mapSection instanceof HTMLElement)) return;

      const isVisible = contentContainer.hasAttribute("data-map-visible");
      if (isVisible === nextVisible) return;

      if (nextVisible) {
        mapSection.hidden = false;
        mapSection.removeAttribute("data-map-closing");
        mapSection.removeAttribute("inert");

        window.requestAnimationFrame(() => {
          contentContainer.toggleAttribute("data-map-visible", true);
        });
      } else {
        mapSection.toggleAttribute("data-map-closing", true);
        contentContainer.toggleAttribute("data-map-visible", false);
        mapSection.toggleAttribute("inert", true);

        const hideAfterTransition = (event) => {
          if (event.target !== mapSection) return;
          if (contentContainer.hasAttribute("data-map-visible")) {
            mapSection.removeEventListener("transitionend", hideAfterTransition);
            return;
          }

          mapSection.hidden = true;
          mapSection.removeAttribute("data-map-closing");
          mapSection.removeEventListener("transitionend", hideAfterTransition);
        };

        mapSection.addEventListener("transitionend", hideAfterTransition);
        window.setTimeout(() => {
          if (!contentContainer.hasAttribute("data-map-visible")) {
            mapSection.hidden = true;
            mapSection.removeAttribute("data-map-closing");
            mapSection.removeEventListener("transitionend", hideAfterTransition);
          }
        }, 360);
      }

      mapSection.toggleAttribute("inert", !nextVisible);

      if (mapToggle instanceof HTMLElement) {
        mapToggle.setAttribute("aria-pressed", String(nextVisible));
        mapToggle.setAttribute("aria-expanded", String(nextVisible));
      }

      if (nextVisible) {
        window.setTimeout(() => {
          document.dispatchEvent(new CustomEvent("map-layout:updated"));
          window.dispatchEvent(new Event("resize"));
        }, 280);
      }
    };

    if (mapToggle instanceof HTMLElement) {
      mapSection?.toggleAttribute("inert", true);
      mapToggle.addEventListener("click", () => {
        const nextVisible = !(contentContainer instanceof HTMLElement && contentContainer.hasAttribute("data-map-visible"));
        setMapVisible(nextVisible);
      });
    }

    const stickyOffset = () => {
      const pagePaddingY = Number.parseFloat(
        getComputedStyle(document.documentElement).getPropertyValue("--page-padding-y")
      );
      return Number.isFinite(pagePaddingY) ? pagePaddingY : 0;
    };

    const syncStickyState = () => {
      if (!(mainHeader instanceof HTMLElement)) return;
      const scrollRootTop = eventsSection instanceof HTMLElement ? eventsSection.getBoundingClientRect().top : 0;
      const isStuck = mainHeader.getBoundingClientRect().top <= scrollRootTop + stickyOffset() + 0.5;
      mainHeader.toggleAttribute("data-stuck", isStuck);
    };

    const maybeCloseFilterOnScroll = () => {
      if (filterExpandedScrollOrigin === null) return;

      const scrollDelta = Math.abs(getScrollTop() - filterExpandedScrollOrigin);
      if (scrollDelta > getScrollHeight() * 0.5) {
        closeFilterDisclosure();
      }
    };

    syncStickyState();
    document.addEventListener("click", (event) => {
      if (!isFilterExpanded()) return;
      if (!(event.target instanceof Node)) return;
      if (root.contains(event.target)) return;

      closeFilterDisclosure();
    });
    document.addEventListener("keydown", (event) => {
      if (event.key !== "Escape") return;

      closeFilterDisclosure();
    });
    getScrollRoot().addEventListener("scroll", syncStickyState, { passive: true });
    getScrollRoot().addEventListener("scroll", maybeCloseFilterOnScroll, { passive: true });
    window.addEventListener("resize", syncStickyState);
  }
</script>

<style lang="sass">
  $mobile-breakpoint: 768px

  .headerWrapper
    display: contents
    :global(.page-edge-strokes--top)
      margin-bottom: calc(var(--page-padding-y) - var(--events-section-gap, 0px))

  .mainHeader
    position: sticky
    top: 0
    z-index: 100
    isolation: isolate
    display: flex
    justify-content: space-between
    align-items: flex-start
    gap: 1.5rem
    padding: var(--stroke-gap) 0
    background-color: var(--color-beige)
    overflow: visible

    &::after
      content: ""
      position: absolute
      z-index: 2
      inset-inline: 0
      bottom: 0
      border-top: var(--stroke-width) solid var(--stroke)
      opacity: 0
      pointer-events: none

      transition: opacity 165ms ease

    &[data-stuck]
      :global(.mainHeader__logo svg)
        height: calc(var(--type-title-size) * 1.22)

      &::after
        opacity: 1

    &__logo
      position: relative
      z-index: 1
      flex: 0 0 auto
      display: block
      padding: 0.125rem 0.25rem 0 0

    &__logo :global(svg)
      width: auto
      height: calc(var(--type-logo-size) * 1.22)
      display: block
      transition: height 165ms ease

  .mainHeader--compact
    &::after
      opacity: 1

    :global(.mainHeader__logo svg)
      height: calc(var(--type-title-size) * 1.22)

  .category-filter
    position: relative
    z-index: 1
    display: flex
    flex-direction: column
    align-items: flex-end
    gap: var(--stroke-gap)
    margin-left: auto
    min-width: 0
    overflow: visible

    &__toolbar
      display: inline-flex
      align-items: flex-start
      justify-content: flex-end
      flex-wrap: wrap
      gap: var(--control-gap)

    &__options
      display: flex
      flex-wrap: wrap
      justify-content: flex-end
      gap: var(--control-gap)
      width: min(100%, 48rem)
      height: 0
      overflow: hidden
      pointer-events: none

      &[data-mobile-open]
        overflow: visible
        pointer-events: auto

  @media (max-width: $mobile-breakpoint)
    .mainHeader
      gap: 1rem
      flex-direction: row
      align-items: flex-start

      &__logo :global(svg)
        height: calc(var(--type-logo-size) * 0.96)

    :global(.mainHeader__filter-toggle)
      display: inline-flex
      align-items: center
      justify-content: flex-start

    .category-filter
      flex: 1 1 auto
      flex-direction: column
      align-items: flex-end

      &__toolbar,
      &__options
        width: 100%

      &__options
        height: 0
        pointer-events: none

        :global([data-filter-button])
          opacity: 0
          pointer-events: none

      &__options[data-mobile-open]
        pointer-events: auto

        :global([data-filter-button])
          pointer-events: auto
</style>

<script>
  import { LOCALE_COOKIE, LOCALE_STORAGE_KEY } from "../lib/i18n";

  if (!window.__localeToggleBound) {
    const localeCookie = LOCALE_COOKIE;
    const localeStorageKey = LOCALE_STORAGE_KEY;
    const maxAgeSeconds = 60 * 60 * 24 * 365;
    const normalizeLocale = (value) => {
      if (typeof value !== "string") return null;
      const normalized = value.trim().toLowerCase();
      if (normalized === "jp" || normalized.startsWith("ja")) return "ja";
      if (normalized.startsWith("en")) return "en";
      return null;
    };
    const getCookieLocale = () => {
      const match = document.cookie
        .split(";")
        .map((part) => part.trim())
        .find((part) => part.startsWith(`${localeCookie}=`));

      return normalizeLocale(match ? decodeURIComponent(match.slice(localeCookie.length + 1)) : "");
    };
    const setLocale = (locale) => {
      document.cookie = `${localeCookie}=${encodeURIComponent(locale)}; Max-Age=${maxAgeSeconds}; Path=/; SameSite=Lax`;
      window.localStorage?.setItem(localeStorageKey, locale);
    };
    const renderedLocale = normalizeLocale(document.documentElement.lang) ?? "en";

    if (getCookieLocale() !== renderedLocale) {
      setLocale(renderedLocale);
    }

    document.addEventListener("click", (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;

      const button = target.closest("[data-locale-option]");
      if (!(button instanceof HTMLElement)) return;

      const nextLocale = normalizeLocale(button.dataset.localeOption);
      if (!nextLocale || nextLocale === renderedLocale) return;

      event.preventDefault();
      setLocale(nextLocale);
      window.location.assign(button.dataset.localeHref || `/${nextLocale}/`);
    });

    window.__localeToggleBound = true;
  }
</script>
