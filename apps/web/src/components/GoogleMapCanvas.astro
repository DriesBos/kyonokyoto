---
type MapSource = {
  slug: string;
  name: string;
  categories: string[];
  lat: number;
  lng: number;
};

type Props = {
  sources?: MapSource[];
};

const { sources = [] } = Astro.props;
const mapsApiKey = import.meta.env.PUBLIC_GOOGLE_MAPS_API_KEY ?? "";
const mapsMapId = import.meta.env.PUBLIC_GOOGLE_MAPS_MAP_ID ?? "";
const sourcesJson = JSON.stringify(sources);
---

<div
  class="map-canvas"
  data-google-map
  data-api-key={mapsApiKey}
  data-map-id={mapsMapId}
  role="application"
  aria-label="Kyoto cultural map"
>
  <script type="application/json" data-map-sources set:html={sourcesJson} />
  <div class="map-controls" data-map-controls>
    <button
      class="map-find-me"
      type="button"
      data-map-find-me
      aria-pressed="false"
      aria-describedby="map-find-me-status"
    >
      find me
    </button>
    <p class="map-find-me-status" id="map-find-me-status" data-map-find-me-status aria-live="polite"></p>
  </div>
  <div class="map-placeholder" data-map-placeholder>
    <p>Map unavailable.</p>
    <p>Add PUBLIC_GOOGLE_MAPS_API_KEY and PUBLIC_GOOGLE_MAPS_MAP_ID.</p>
  </div>
</div>

<script>
  import "../scripts/googleMap";
</script>

<style lang="sass">
  $mobile-breakpoint: 768px

  .map-canvas
    position: relative
    width: 100%
    height: 100%
    min-height: 0
    background: var(--color-beige)
    color: var(--color-green)
    overflow: hidden

    :global(.gm-style)
      font-family: var(--font-body)
    :global(.gm-style-cc)
      opacity: 0
    :global(.gm-style img[alt="Google"])
      background: var(--color-beige)
      border-radius: 2px
      box-shadow: 0 0 0 3px var(--color-beige)
      opacity: 0
    :global(.gm-style-mtc)
      opacity: 0

  .map-placeholder
    position: absolute
    inset: 0
    z-index: 1
    display: grid
    place-content: center
    gap: 0.25rem
    padding: 2rem
    background: var(--color-beige)
    color: var(--color-green)
    text-align: center

    &[hidden]
      display: none

    p
      margin: 0

  .map-controls
    position: absolute
    right: var(--page-padding-x)
    bottom: var(--page-padding-y)
    z-index: 2
    display: flex
    flex-direction: column
    align-items: flex-end
    gap: 0.25rem
    pointer-events: none

  .map-find-me
    padding: 1px
    border: 1px solid white
    border-radius: 4px
    appearance: none
    -webkit-tap-highlight-color: transparent
    background: var(--color-beige)
    color: var(--color-green)
    font: inherit
    font-size: 12px
    line-height: 1
    text-transform: lowercase
    cursor: var(--dot-cursor)
    pointer-events: auto

    &[aria-pressed='true']
      background: var(--color-pink)

    &:disabled
      opacity: 0.55

    &:focus,
    &:focus-visible
      outline: none

  .map-find-me-status
    max-width: 12rem
    margin: 0
    padding: 1px
    border: 1px solid white
    border-radius: 4px
    background: var(--color-beige)
    color: var(--color-green)
    font-size: 12px
    line-height: 1.15
    text-align: right
    pointer-events: none

    &:empty
      display: none

  :global(.map-marker)
    --map-marker-size: 1.25rem

    display: grid
    place-items: center
    min-width: var(--map-marker-size)
    min-height: var(--map-marker-size)
    padding: 0
    border: 0
    appearance: none
    -webkit-tap-highlight-color: transparent
    background: transparent
    color: var(--color-green)
    cursor: var(--dot-cursor)
    transform: translateY(-0.25rem) scale(var(--map-marker-scale, 1))
    transform-origin: center
    transition: transform 180ms cubic-bezier(0.16, 1, 0.3, 1)

    &[data-highlighted]
      --map-marker-scale: 1

    &[data-hidden]
      display: none

  :global(.map-marker__dot)
    display: block
    box-sizing: border-box
    width: 100%
    height: 100%
    background: var(--color-pink)
    border: 1px solid white
    border-radius: 999px
    box-shadow: none
    transition: transform 160ms ease

  :global(.map-marker:hover .map-marker__dot),
  :global(.map-marker:focus-visible .map-marker__dot)
    transform: scale(1.33)

  :global(.map-marker[data-highlighted] .map-marker__dot)
    display: none

  :global(.map-marker__label)
    display: none
    max-width: 10rem
    padding: 3px 6px
    border: 1px solid white
    border-radius: 1000px
    background: var(--color-pink)
    color: white
    font-size: 12px
    line-height: 1
    text-align: center
    white-space: nowrap
    overflow: hidden
    text-overflow: ellipsis

  :global(.map-marker[data-highlighted] .map-marker__label)
    display: block

  :global(.map-marker:focus-visible)
    outline: none

  :global(.map-user-marker)
    --map-user-heading: 0deg
    position: relative
    width: 1.25rem
    height: 1.25rem
    border: 1px solid white
    border-radius: 999px
    background: var(--color-pink)
    box-sizing: border-box

    &::before
      content: ""
      position: absolute
      left: 50%
      top: -0.55rem
      width: 0
      height: 0
      border-left: 0.28rem solid transparent
      border-right: 0.28rem solid transparent
      border-bottom: 0.65rem solid var(--color-green)
      transform: translateX(-50%) rotate(var(--map-user-heading))
      transform-origin: 50% calc(100% + 0.65rem)
</style>
