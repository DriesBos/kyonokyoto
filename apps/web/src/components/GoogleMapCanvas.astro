---
type MapSource = {
  slug: string;
  name: string;
  categories: string[];
  lat: number;
  lng: number;
};

type Props = {
  sources?: MapSource[];
};

const { sources = [] } = Astro.props;
const mapsApiKey = import.meta.env.PUBLIC_GOOGLE_MAPS_API_KEY ?? "";
const mapsMapId = import.meta.env.PUBLIC_GOOGLE_MAPS_MAP_ID ?? "";
const sourcesJson = JSON.stringify(sources);
---

<div
  class="map-canvas"
  data-google-map
  data-api-key={mapsApiKey}
  data-map-id={mapsMapId}
  role="application"
  aria-label="Kyoto cultural map"
>
  <script type="application/json" data-map-sources set:html={sourcesJson} />
  <div class="map-placeholder" data-map-placeholder>
    <p>Map unavailable.</p>
    <p>Add PUBLIC_GOOGLE_MAPS_API_KEY and PUBLIC_GOOGLE_MAPS_MAP_ID.</p>
  </div>
</div>

<script>
  import "../scripts/googleMap";
</script>

<style lang="sass">
  $mobile-breakpoint: 768px

  .map-canvas
    position: relative
    width: 100%
    height: 100%
    min-height: 0
    background: var(--color-beige)
    color: var(--color-green)
    overflow: hidden
    @media screen and (min-width: $mobile-breakpoint)
      border-left: var(--stroke-width) solid var(--color-green)
    @media screen and (max-width: $mobile-breakpoint)
      border-bottom: var(--stroke-width) solid var(--color-green)

    :global(.gm-style)
      font-family: var(--font-body)
    :global(.gm-style-cc)
      opacity: 0
    :global(.gm-style img[alt="Google"])
      background: var(--color-beige)
      border-radius: 2px
      box-shadow: 0 0 0 3px var(--color-beige)
      opacity: 0
    :global(.gm-style-mtc)
      opacity: 0

  .map-placeholder
    position: absolute
    inset: 0
    z-index: 1
    display: grid
    place-content: center
    gap: 0.25rem
    padding: 2rem
    background: var(--color-beige)
    color: var(--color-green)
    text-align: center

    &[hidden]
      display: none

    p
      margin: 0

  :global(.map-marker)
    --map-marker-size: 1.25rem

    display: grid
    place-items: center
    width: var(--map-marker-size)
    height: var(--map-marker-size)
    padding: 0
    border: 0
    appearance: none
    -webkit-tap-highlight-color: transparent
    background: transparent
    color: var(--color-green)
    cursor: var(--dot-cursor)
    transform: translateY(-0.25rem) scale(var(--map-marker-scale, 1))
    transform-origin: center
    transition: transform 180ms cubic-bezier(0.16, 1, 0.3, 1)

    &[data-highlighted]
      --map-marker-scale: 1.66

    &[data-hidden]
      display: none

  :global(.map-marker__dot)
    display: block
    box-sizing: border-box
    width: 100%
    height: 100%
    background: var(--color-pink)
    border: 1px solid white
    border-radius: 999px
    box-shadow: none
    transition: transform 160ms ease

  :global(.map-marker:hover .map-marker__dot),
  :global(.map-marker:focus-visible .map-marker__dot)
    transform: scale(1.33)

  :global(.map-marker[data-highlighted] .map-marker__dot)
    border-color: var(--color-green)

  :global(.map-marker:focus-visible)
    outline: none
</style>
