---
type IconName = "arrow" | "arrow-long" | "calendar" | "exit" | "map" | "sound";
type IconDirection = "top" | "right" | "bottom" | "left";

type Props = {
  name: IconName;
  direction?: IconDirection;
  rotation?: IconDirection;
  class?: string;
  title?: string;
};

const { name, direction, rotation, class: className, title } = Astro.props;
const labelled = Boolean(title);
const iconDirection = rotation ?? direction;
const classes = ["icon", `icon--${name}`, name === "arrow-long" && "icon--long", iconDirection && `icon--${iconDirection}`, className];
