    <svg
      class:list={classes}
      viewBox="0 0 25 25"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden={labelled ? undefined : "true"}
      role={labelled ? "img" : undefined}
    >
      {title ? <title>{title}</title> : null}
