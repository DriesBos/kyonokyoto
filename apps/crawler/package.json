{
  "name": "kyo-no-kyoto-crawler",
  "private": true,
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "crawl:once": "node src/run-once.mjs",
    "crawl:all": "node src/run-once.mjs --source=all",
    "crawl:kac": "node src/run-once.mjs --source=kyoto-art-center",
    "crawl:kyocera": "node src/run-once.mjs --source=kyoto-city-kyocera-museum-of-art",
    "crawl:momak": "node src/run-once.mjs --source=the-national-museum-of-modern-art",
    "crawl:sen-oku": "node src/run-once.mjs --source=sen-oku-hakukokan-museum",
    "test": "node --test test/*.test.mjs"
  }
}
