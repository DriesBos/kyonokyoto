{
  "name": "kyo-no-kyoto-crawler",
  "private": true,
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "crawl:once": "node src/run-once.mjs",
    "crawl:all": "node src/run-once.mjs --source=all",
    "crawl:kyoto": "node src/run-once.mjs --city=kyoto --source=all",
    "crawl:osaka": "node src/run-once.mjs --city=osaka --source=all",
    "crawl:tokyo": "node src/run-once.mjs --city=tokyo --source=all",
    "crawl:replay": "node src/replay-latest.mjs",
    "crawl:kac": "node src/run-once.mjs --source=kyoto-art-center",
    "crawl:kyocera": "node src/run-once.mjs --source=kyoto-city-kyocera-museum-of-art",
    "crawl:momak": "node src/run-once.mjs --source=momak",
    "crawl:sen-oku": "node src/run-once.mjs --source=sen-oku-hakukokan",
    "translations:backfill": "node src/backfill-translations.mjs",
    "translations:check": "node src/check-translations.mjs",
    "test": "node --test test/*.test.mjs && python3 -B -m unittest discover -s test -p 'test_*.py'"
  },
  "dependencies": {
    "@google-cloud/translate": "^9.4.2"
  }
}
