# Crawler runtime values
# SUPABASE_URL=https://xbnmaaeqzmgsvjmovtrr.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=

# Optional if we write directly to Postgres from the crawler
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xbnmaaeqzmgsvjmovtrr.supabase.co:5432/postgres

# Optional if we want each successful crawl cycle to trigger a fresh web deploy
# NETLIFY_BUILD_HOOK_URL=

# Crawl behavior
# CRAWLER_TIMEZONE=Asia/Tokyo
# CRAWLER_SCHEDULE=15 3 * * *
# CRAWLER_USER_AGENT=kyo-no-kyoto-bot/0.1
# LOG_LEVEL=info
# CRAWLER_FETCH_TIMEOUT_MS=30000
# CRAWLER_FETCH_RETRIES=2
# CRAWLER_RETRY_BASE_DELAY_MS=1000
# CRAWLER_MIN_DELAY_MS=1000
# CRAWLER_MAX_DELAY_MS=3000

# Optional Crawl4AI browser rendering for JS/lazy-loaded images on the VPS.
# auto: static fetch first, then render detail pages that have no image.
# always: render listing and detail pages with Crawl4AI.
# never: only use static fetch.
# CRAWL4AI_RENDER_MODE=auto
# CRAWL4AI_PYTHON=python3
# CRAWL4AI_WAIT_FOR_IMAGES=true
# CRAWL4AI_SCAN_FULL_PAGE=true
# CRAWL4AI_SCROLL_DELAY=0.5
# CRAWL4AI_PAGE_TIMEOUT_MS=45000
# CRAWL4AI_BYPASS_CACHE=true
# CRAWL4AI_MAX_RENDERS_PER_SOURCE=5
