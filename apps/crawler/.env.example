# Crawler runtime values
# SUPABASE_URL=https://xbnmaaeqzmgsvjmovtrr.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=

# Optional if we write directly to Postgres from the crawler
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xbnmaaeqzmgsvjmovtrr.supabase.co:5432/postgres

# Optional external monitoring. Heartbeat receives successful cycles only.
# Alert webhook receives degraded and failed cycle JSON.
# CRAWL_HEARTBEAT_URL=
# CRAWL_ALERT_WEBHOOK_URL=

# Crawl behavior
# CRAWLER_TIMEZONE=Asia/Tokyo
# CRAWLER_SCHEDULE=15 3 * * *
# Set a real project/contact URL before production crawling.
# CRAWLER_USER_AGENT=kyo-no-kyoto-bot/0.2 (+https://your-domain.example/bot)
# LOG_LEVEL=info
# CRAWLER_FETCH_TIMEOUT_MS=30000
# CRAWLER_FETCH_RETRIES=2
# CRAWLER_RETRY_BASE_DELAY_MS=1000
# CRAWLER_IMAGE_PROBE_TIMEOUT_MS=10000
# CRAWLER_MIN_DELAY_MS=1000
# CRAWLER_MAX_DELAY_MS=3000
# Hard safety cap. Applies even to source-specific extractors.
# CRAWLER_MAX_DETAIL_PAGES_PER_SOURCE=50
# CRAWLER_RESPECT_ROBOTS_TXT=true
# CRAWLER_ROBOTS_TIMEOUT_MS=10000

# Optional Google Cloud Translation fallback for missing EN/JA event copy.
# Requires Google Application Default Credentials or GOOGLE_APPLICATION_CREDENTIALS.
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_TRANSLATE_PROJECT_ID=
# GOOGLE_TRANSLATE_LOCATION=global
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/google-service-account.json

# Optional Crawl4AI browser rendering for JS/lazy-loaded images on the VPS.
# auto: static fetch first, then render suspicious pages or detail pages with no image/valid title.
# always: render listing and detail pages with Crawl4AI.
# never: only use static fetch.
# CRAWL4AI_RENDER_MODE=auto
# Crawl4AI 0.7.4 requires Python 3.10+.
# CRAWL4AI_PYTHON=python3.12
# CRAWL4_AI_BASE_DIRECTORY=/absolute/writable/cache/root
# CRAWL4AI_WAIT_FOR_IMAGES=true
# Keep false globally. Enable crawl_hints.scan_full_page only for sources with proven lazy media.
# CRAWL4AI_SCAN_FULL_PAGE=false
# CRAWL4AI_SCROLL_DELAY=0.5
# CRAWL4AI_PAGE_TIMEOUT_MS=45000
# CRAWL4AI_BYPASS_CACHE=true
# CRAWL4AI_MAX_RENDERS_PER_SOURCE=5
